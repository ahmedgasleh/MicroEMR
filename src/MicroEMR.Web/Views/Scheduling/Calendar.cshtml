@model MicroEMR.Application.Scheduling.DTOs.CalendarViewDto

@{
    ViewData["Title"] = "Calendar";
}

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h2>@Model.ProviderName's Schedule</h2>
            @if (!string.IsNullOrEmpty(Model.ResourceName))
            {
                <p class="text-muted">Resource: @Model.ResourceName</p>
            }
        </div>
        <div class="col-md-4 text-end">
            <button class="btn btn-primary" onclick="goToPreviousDay()">← Previous</button>
            <span class="mx-2">@Model.ViewDate.ToString("dddd, MMMM d, yyyy")</span>
            <button class="btn btn-primary" onclick="goToNextDay()">Next →</button>
            <button class="btn btn-secondary" onclick="goToToday()">Today</button>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-9">
            <!-- Calendar Grid -->
            <div class="card">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Schedule Grid (15-minute slots)</h5>
                </div>
                <div class="card-body p-0">
                    <div class="schedule-grid" style="max-height: 600px; overflow-y: auto;">
                        <table class="table table-bordered table-sm mb-0">
                            <thead class="table-light sticky-top">
                                <tr>
                                    <th style="width: 80px;">Time</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    var startHour = 8;
                                    var endHour = 17;
                                    var currentDate = Model.ViewDate.Date;
                                }
                                @for (int hour = startHour; hour < endHour; hour++)
                                {
                                    for (int minute = 0; minute < 60; minute += 15)
                                    {
                                        var slotTime = new DateTime(currentDate.Year, currentDate.Month, currentDate.Day, hour, minute, 0);
                                        var slot = Model.AvailableSlots.FirstOrDefault(s => s.SlotStartTime == slotTime);
                                        var appointment = Model.Appointments.FirstOrDefault(a => a.StartAt <= slotTime && a.EndAt > slotTime);
                                        var block = Model.ResourceBlocks.FirstOrDefault(b => b.BlockStartTime <= slotTime && b.BlockEndTime > slotTime);

                                        var statusClass = "available";
                                        var statusText = "Available";
                                        var statusColor = "bg-success";

                                        if (appointment != null)
                                        {
                                            statusClass = "booked";
                                            statusText = $"{appointment.PatientName}";
                                            statusColor = "bg-info";
                                        }
                                        else if (block != null)
                                        {
                                            statusClass = "blocked";
                                            statusText = $"Blocked: {block.Reason}";
                                            statusColor = "bg-danger";
                                        }
                                        else if (slot?.Status == "Blocked")
                                        {
                                            statusClass = "blocked";
                                            statusText = $"Blocked: {slot.BlockReason}";
                                            statusColor = "bg-warning";
                                        }

                                        @if (minute == 0)
                                        {
                                            <tr>
                                                <td class="fw-bold">@slotTime.ToString("HH:mm")</td>
                                                <td class="@statusColor text-white p-2" style="min-height: 50px; cursor: pointer;" 
                                                    onclick="@(statusClass == "available" ? $"selectSlot('{slot?.Id}', '{slotTime:yyyy-MM-ddTHH:mm}')" : "")">
                                                    @statusText
                                                </td>
                                            </tr>
                                        }
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-3">
            <!-- Sidebar Info -->
            <div class="card mb-3">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Today's Appointments</h5>
                </div>
                <div class="card-body p-0">
                    @if (Model.Appointments.Any())
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var apt in Model.Appointments.OrderBy(a => a.StartAt))
                            {
                                <li class="list-group-item">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div>
                                            <strong>@apt.PatientName</strong>
                                            <br />
                                            <small class="text-muted">@apt.StartAt.ToString("HH:mm") - @apt.EndAt.ToString("HH:mm")</small>
                                            <br />
                                            <small>@apt.AppointmentType</small>
                                            <br />
                                            <span class="badge @(apt.IsConfirmed ? "bg-success" : "bg-warning")">
                                                @(apt.IsConfirmed ? "Confirmed" : "Pending")
                                            </span>
                                        </div>
                                        <div class="btn-group-vertical btn-group-sm">
                                            <a href="@Url.Action("RescheduleAppointment", new { appointmentId = apt.Id })" 
                                               class="btn btn-outline-primary btn-sm" title="Reschedule">
                                                <i class="fas fa-calendar-check"></i>
                                            </a>
                                            <button class="btn btn-outline-danger btn-sm" 
                                                    onclick="cancelAppointment('@apt.Id')" title="Cancel">
                                                <i class="fas fa-times"></i>
                                            </button>
                                            <a href="@Url.Action("AppointmentHistory", new { appointmentId = apt.Id })" 
                                               class="btn btn-outline-info btn-sm" title="History">
                                                <i class="fas fa-history"></i>
                                            </a>
                                        </div>
                                    </div>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p class="card-text text-center text-muted py-3">No appointments scheduled</p>
                    }
                </div>
            </div>

            <div class="card">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Quick Actions</h5>
                </div>
                <div class="card-body">
                    <a href="@Url.Action("CreateAppointment", new { providerId = Model.ProviderId })" 
                       class="btn btn-primary btn-sm w-100 mb-2">
                        <i class="fas fa-plus"></i> New Appointment
                    </a>
                    <a href="@Url.Action("ManageResourceBlocks", new { providerId = Model.ProviderId, resourceId = (Model.ClinicResourceId ?? Guid.Empty) })" 
                       class="btn btn-warning btn-sm w-100 mb-2">
                        <i class="fas fa-lock"></i> Resource Blocks
                    </a>
                    <button class="btn btn-info btn-sm w-100" onclick="exportCalendar()">
                        <i class="fas fa-download"></i> Export
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function selectSlot(slotId, slotTime) {
            if (slotId) {
                window.location.href = '@Url.Action("CreateAppointment")' + '?providerId=@Model.ProviderId&slotId=' + slotId;
            }
        }

        function cancelAppointment(appointmentId) {
            if (confirm('Are you sure you want to cancel this appointment?')) {
                const reason = prompt('Enter cancellation reason:');
                if (reason) {
                    fetch('@Url.Action("CancelAppointment")', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({
                            appointmentId: appointmentId,
                            reason: reason
                        })
                    })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            location.reload();
                        } else {
                            alert('Error: ' + data.error);
                        }
                    });
                }
            }
        }

        function goToPreviousDay() {
            const currentDate = new Date('@Model.ViewDate.ToString("yyyy-MM-dd")');
            currentDate.setDate(currentDate.getDate() - 1);
            window.location.href = '@Url.Action("Calendar")' + 
                '?providerId=@Model.ProviderId&viewDate=' + currentDate.toISOString().split('T')[0];
        }

        function goToNextDay() {
            const currentDate = new Date('@Model.ViewDate.ToString("yyyy-MM-dd")');
            currentDate.setDate(currentDate.getDate() + 1);
            window.location.href = '@Url.Action("Calendar")' + 
                '?providerId=@Model.ProviderId&viewDate=' + currentDate.toISOString().split('T')[0];
        }

        function goToToday() {
            window.location.href = '@Url.Action("Calendar")' + '?providerId=@Model.ProviderId';
        }

        function exportCalendar() {
            alert('Export functionality coming soon');
        }
    </script>
}
