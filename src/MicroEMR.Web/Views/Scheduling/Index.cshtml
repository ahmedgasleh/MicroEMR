@if (TempData["Error"] is string errorMessage)
{
    <div class="alert alert-warning" role="alert">
        @errorMessage
    </div>
}

<div class="scheduling-view-bar">
    <div>
        <h2 class="h5 mb-2" id="schedulingViewTitle">Day View</h2>
        <div class="btn-group" role="group" aria-label="Scheduling calendar view">
            <button type="button" class="btn btn-outline-secondary" id="schedulingMonthViewButton" aria-pressed="false">
                Month
            </button>
            <button type="button" class="btn btn-primary" id="schedulingDayViewButton" aria-pressed="true">
                Day
            </button>
        </div>
    </div>

    <div class="text-body-secondary small">
        Appointment booking is available in Day View.
    </div>
</div>

<div id="schedulingMonthView" class="d-none">
    <div class="scheduling-month-toolbar">
        <div class="scheduling-toolbar-actions" aria-label="Scheduling month navigation">
            <button type="button" class="btn btn-outline-secondary" id="schedulingPreviousMonthButton">Previous Month</button>
            <button type="button" class="btn btn-outline-primary" id="schedulingMonthTodayButton">Today</button>
            <button type="button" class="btn btn-outline-secondary" id="schedulingNextMonthButton">Next Month</button>
        </div>
        <div class="scheduling-date-label" id="schedulingMonthLabel"></div>
    </div>
    <div id="schedulingMonthMessage" class="alert alert-warning d-none" role="alert"></div>
    <div class="scheduling-month-grid" id="schedulingMonthGrid" aria-label="Monthly appointment overview"></div>
</div>

<div id="schedulingDayView">
<div class="scheduling-toolbar">
    <div class="scheduling-toolbar-actions" aria-label="Scheduling date navigation">

        <button type="button" class="btn btn-outline-secondary" id="schedulingPreviousButton">
            Previous
        </button>

        <button type="button" class="btn btn-outline-primary" id="schedulingTodayButton">
            Today
        </button>

        <button type="button" class="btn btn-outline-secondary" id="schedulingNextButton">
            Next
        </button>

        <div class="scheduling-date-label" id="schedulingDateLabel">
        </div>
    </div>

    <div class="scheduling-filter-panel">
        <div class="scheduling-filter-field">
            <label class="form-label" for="schedulingResourceTypeFilter">Type</label>
            <select class="form-select" id="schedulingResourceTypeFilter">
                <option value="">All</option>
                <option value="Provider">Providers</option>
                <option value="Room">Rooms</option>
            </select>
        </div>
        <div class="scheduling-filter-field">
            <label class="form-label d-block">Resources</label>
            <button type="button" class="btn btn-outline-secondary" id="openResourcePickerButton">
                Select Resources
            </button>
        </div>
        <div class="scheduling-filter-summary" id="resourceFilterSummary">Showing all active resources</div>
    </div>
</div>

<div id="resourceFilterMessage" class="alert alert-info d-none py-2" role="status"></div>

<div class="modal fade" id="resourcePickerModal" tabindex="-1" aria-labelledby="resourcePickerModalLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title fs-5" id="resourcePickerModalLabel">Select Scheduling Resources</h2>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <label class="form-label" for="resourcePickerSearch">Search resources</label>
                <input type="search" class="form-control mb-3" id="resourcePickerSearch"
                       placeholder="Resource name" autocomplete="off" />
                <div class="resource-picker-list list-group" id="resourcePickerList"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" id="clearResourceSelectionButton">Clear</button>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="applyResourceSelectionButton">Apply</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="appointmentDetailsModal" tabindex="-1" aria-labelledby="appointmentDetailsModalLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title fs-5" id="appointmentDetailsModalLabel">Appointment Details</h2>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div id="appointmentDetailsLoading" class="text-center py-4">
                    <div class="spinner-border text-primary" role="status"><span class="visually-hidden">Loading</span>
                    </div>
                    <div class="mt-2">Loading appointment details...</div>
                </div>
                <div id="appointmentDetailsError" class="alert alert-danger d-none" role="alert"></div>
                <dl id="appointmentDetailsContent" class="row mb-0 d-none">
                    <dt class="col-sm-4">Patient</dt>
                    <dd class="col-sm-8" id="detailsPatient"></dd>
                    <dt class="col-sm-4">Chart number</dt>
                    <dd class="col-sm-8" id="detailsChartNumber"></dd>
                    <dt class="col-sm-4">Status</dt>
                    <dd class="col-sm-8" id="detailsStatus"></dd>
                    <dt class="col-sm-4">Date</dt>
                    <dd class="col-sm-8" id="detailsDate"></dd>
                    <dt class="col-sm-4">Start time</dt>
                    <dd class="col-sm-8" id="detailsStartTime"></dd>
                    <dt class="col-sm-4">End time</dt>
                    <dd class="col-sm-8" id="detailsEndTime"></dd>
                    <dt class="col-sm-4">Provider/resource</dt>
                    <dd class="col-sm-8" id="detailsPrimaryResource"></dd>
                    <dt class="col-sm-4">Room</dt>
                    <dd class="col-sm-8" id="detailsRoom"></dd>
                    <dt class="col-sm-4">Appointment type</dt>
                    <dd class="col-sm-8" id="detailsType"></dd>
                    <dt class="col-sm-4">Reason</dt>
                    <dd class="col-sm-8" id="detailsReason"></dd>
                    <dt class="col-sm-4">Notes</dt>
                    <dd class="col-sm-8 text-break" id="detailsNotes"></dd>
                    <dt class="col-sm-4">Created by</dt>
                    <dd class="col-sm-8" id="detailsCreatedBy"></dd>
                    <dt class="col-sm-4">Created date</dt>
                    <dd class="col-sm-8" id="detailsCreatedAt"></dd>
                </dl>
            </div>
            <div class="modal-footer">
                <a id="openPatientChartButton" class="btn btn-primary d-none" href="#">Open Chart</a>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<form id="schedulingAntiforgeryForm" class="d-none">@Html.AntiForgeryToken()</form>

<div class="modal fade" id="moveAppointmentModal" tabindex="-1" aria-labelledby="moveAppointmentModalLabel"
     aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title fs-5" id="moveAppointmentModalLabel">Confirm Appointment Move</h2>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div id="moveAppointmentMessage" class="alert alert-danger d-none" role="alert"></div>
                <p class="mb-0" id="moveAppointmentSummary"></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" id="keepCurrentTimeButton">Keep Current Time</button>
                <button type="button" class="btn btn-primary" id="confirmMoveButton">Confirm Move</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="addAppointmentModal" tabindex="-1" aria-labelledby="addAppointmentModalLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title fs-5" id="addAppointmentModalLabel">Add Appointment</h2>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div id="appointmentMessage" class="alert d-none" role="alert"></div>
                <form id="addAppointmentForm" novalidate>
                    <input type="hidden" id="PatientUid" name="PatientUid" />
                    <div class="mb-3">
                        <label for="patientSearchTerm" class="form-label">Patient</label>
                        <div class="input-group">
                            <input id="patientSearchTerm" class="form-control" autocomplete="off"
                                   placeholder="Name or chart number" />
                            <button id="patientSearchButton" class="btn btn-outline-primary"
                                    type="button">Search</button>
                        </div>
                        <div id="selectedPatientLabel" class="form-text">No patient selected.</div>
                        <div id="patientSearchResults" class="list-group mt-2"></div>
                        <div class="invalid-feedback" data-error-for="PatientUid"></div>
                    </div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label for="PrimaryResourceUid" class="form-label">Primary resource</label>
                            <select id="PrimaryResourceUid" name="PrimaryResourceUid" class="form-select">
                                <option value="">Select resource</option>
                                @foreach (var resource in Model.Resources.OrderBy(r => r.ResourceType == "Provider" ? 0
                                : 1).ThenBy(r => r.SortOrder))
                                {
                                    <option value="@resource.ResourceUid">@resource.DisplayName (@resource.ResourceType)
                                    </option>
                                }
                            </select>
                            <div class="invalid-feedback" data-error-for="PrimaryResourceUid"></div>
                        </div>
                        <div class="col-md-6">
                            <label for="RoomResourceUid" class="form-label">Room (optional)</label>
                            <select id="RoomResourceUid" name="RoomResourceUid" class="form-select">
                                <option value="">No room</option>
                                @foreach (var room in Model.Resources.Where(r => r.ResourceType == "Room").OrderBy(r =>
                                r.SortOrder))
                                {
                                    <option value="@room.ResourceUid">@room.DisplayName</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label for="StartDateTimeLocal" class="form-label">Start</label>
                            <input id="StartDateTimeLocal" name="StartDateTimeLocal" type="datetime-local"
                                   class="form-control" />
                            <div class="invalid-feedback" data-error-for="StartDateTimeLocal"></div>
                        </div>
                        <div class="col-md-6">
                            <label for="EndDateTimeLocal" class="form-label">End</label>
                            <input id="EndDateTimeLocal" name="EndDateTimeLocal" type="datetime-local"
                                   class="form-control" />
                            <div class="invalid-feedback" data-error-for="EndDateTimeLocal"></div>
                        </div>
                        <div class="col-md-6">
                            <label for="AppointmentType" class="form-label">Appointment type</label>
                            <select id="AppointmentType" name="AppointmentType" class="form-select">
                                <option value="">Select type</option>
                                @foreach (var type in new[] { "Office Visit", "Phone Visit", "Virtual Visit",
             "Follow-up", "Consultation", "Procedure", "Other" })
                                {
                                    <option value="@type">@type</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label for="Reason" class="form-label">Reason</label>
                            <input id="Reason" name="Reason" maxlength="500" class="form-control" />
                            <div class="invalid-feedback" data-error-for="Reason"></div>
                        </div>
                        <div class="col-12">
                            <label for="Notes" class="form-label">Notes</label>
                            <textarea id="Notes" name="Notes" maxlength="1000" rows="3" class="form-control"></textarea>
                            <div class="invalid-feedback" data-error-for="Notes"></div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="saveAppointmentButton">Save Appointment</button>
            </div>
        </div>
    </div>
</div>

@if (Model.Resources.Count == 0)
{
    <div class="scheduling-empty-state">
        No active scheduling resources were returned by the API.
    </div>
}
else
{
    <div class="scheduling-calendar-shell">
        <div id="schedulingCalendar"></div>
    </div>
}
</div>

@section Scripts {
    <script src="~/lib/daypilot/daypilot-javascript.min.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", () => {
        if (!window.DayPilot) {
        console.error("DayPilot Lite could not be loaded.");
        return;
        }

        const resources = @Html.Raw(resourcesJson);

        if (!resources.length) {
        return;
        }

        let selectedDate = DayPilot.Date.today();
        let currentView = "day";
        let selectedMonthDate = new Date();
        selectedMonthDate.setHours(0, 0, 0, 0);
        let selectedResourceType = "";
        let selectedResourceUids = new Set();
        let pendingResourceUids = new Set();
        const resourceTypeFilter = document.getElementById("schedulingResourceTypeFilter");
        const resourceFilterSummary = document.getElementById("resourceFilterSummary");
        const resourceFilterMessage = document.getElementById("resourceFilterMessage");

        const dateLabel =
        document.getElementById("schedulingDateLabel");
        const dayView = document.getElementById("schedulingDayView");
        const monthView = document.getElementById("schedulingMonthView");
        const dayViewButton = document.getElementById("schedulingDayViewButton");
        const monthViewButton = document.getElementById("schedulingMonthViewButton");
        const viewTitle = document.getElementById("schedulingViewTitle");
        const monthGrid = document.getElementById("schedulingMonthGrid");
        const monthLabel = document.getElementById("schedulingMonthLabel");
        const monthMessage = document.getElementById("schedulingMonthMessage");

        const getMatchingResources = () => resources.filter(resource =>
        (!selectedResourceType || resource.resourceType === selectedResourceType) &&
        (!selectedResourceUids.size || selectedResourceUids.has(resource.resourceUid)));

        const getFilteredResources = () => getMatchingResources().slice(0, 10);

        const toColumns = () => getFilteredResources()
        .map(resource => ({
        id: resource.resourceUid,
        name: resource.displayName
        }));

        const updateResourceFilterSummary = () => {
        const matchingCount = getMatchingResources().length;
        const visibleCount = Math.min(matchingCount, 10);
        resourceFilterSummary.textContent = matchingCount
        ? `Showing ${visibleCount} ${visibleCount === 1 ? "resource" : "resources"}`
        : "No resources match the selected filter";
        resourceFilterMessage.classList.toggle("d-none", matchingCount <= 10 && matchingCount > 0);
        resourceFilterMessage.textContent = matchingCount > 10
        ? "Showing first 10 resources. Use Select Resources to narrow the view."
        : (matchingCount === 0 ? "No resources match the selected filter." : "");
        };

        const calendar = new DayPilot.Calendar(
        "schedulingCalendar",
        {
        viewType: "Resources",
        columns: toColumns(),
        startDate: selectedDate,
        cellDuration: 15,
        businessBeginsHour: 8,
        businessEndsHour: 18,
        eventMoveHandling: "Update",
        eventResizeHandling: "Disabled",
        eventDeleteHandling: "Disabled",
        timeRangeSelectedHandling: "Enabled",
        onEventMove: async args => {
        args.preventDefault();
        const destination = resources.find(resource => resource.resourceUid === args.newResource);
        if (destination?.resourceType !== "Provider") {
        await refreshCalendar();
        window.alert("Appointments can only be moved between provider columns.");
        return;
        }
        try {
        const detailsUrl = new URL("/Scheduling/AppointmentDetails", window.location.origin);
        detailsUrl.searchParams.set("appointmentUid", args.e.id());
        const detailsResponse = await fetch(detailsUrl);
        if (!detailsResponse.ok) throw new Error(`Appointment details request failed: ${detailsResponse.status}`);
        const details = await detailsResponse.json();
        pendingMove = {
        appointmentUid: args.e.id(),
        primaryResourceUid: args.newResource,
        roomResourceUid: details.roomResourceUid || null,
        startDateTimeLocal: args.newStart.toDateLocal(),
        endDateTimeLocal: args.newEnd.toDateLocal()
        };

        const start = pendingMove.startDateTimeLocal;
        const end = pendingMove.endDateTimeLocal;
        moveAppointmentSummary.textContent =
        `Move to ${destination?.displayName || "the selected resource"} on ${start.toLocaleDateString()} ` +
        `from ${start.toLocaleTimeString([], { hour: "numeric", minute: "2-digit" })} ` +
        `to ${end.toLocaleTimeString([], { hour: "numeric", minute: "2-digit" })}?`;
        moveAppointmentMessage.classList.add("d-none");
        moveAppointmentMessage.textContent = "";
        moveAppointmentModal.show();
        } catch (error) {
        console.error(error);
        pendingMove = null;
        await refreshCalendar();
        window.alert("The appointment could not be prepared for rescheduling. Please try again.");
        }
        },
        onTimeRangeSelected: args => {
        openAppointmentModal(args.start, args.resource);
        calendar.clearSelection();
        },
        onEventClick: args => openAppointmentDetails(args.e.id())
        });

        calendar.init();

        const appointmentModal = new bootstrap.Modal(document.getElementById("addAppointmentModal"));
        const resourcePickerModal = new bootstrap.Modal(document.getElementById("resourcePickerModal"));
        const resourcePickerSearch = document.getElementById("resourcePickerSearch");
        const resourcePickerList = document.getElementById("resourcePickerList");
        const moveAppointmentModalElement = document.getElementById("moveAppointmentModal");
        const moveAppointmentModal = new bootstrap.Modal(moveAppointmentModalElement);
        const moveAppointmentSummary = document.getElementById("moveAppointmentSummary");
        const moveAppointmentMessage = document.getElementById("moveAppointmentMessage");
        const confirmMoveButton = document.getElementById("confirmMoveButton");
        let pendingMove = null;
        const appointmentForm = document.getElementById("addAppointmentForm");
        const appointmentMessage = document.getElementById("appointmentMessage");
        const selectedPatientLabel = document.getElementById("selectedPatientLabel");
        const searchResults = document.getElementById("patientSearchResults");
        const detailsModal = new bootstrap.Modal(document.getElementById("appointmentDetailsModal"));
        const detailsLoading = document.getElementById("appointmentDetailsLoading");
        const detailsError = document.getElementById("appointmentDetailsError");
        const detailsContent = document.getElementById("appointmentDetailsContent");
        const openChartButton = document.getElementById("openPatientChartButton");
        const patientChartBaseUrl = @Html.Raw(JsonSerializer.Serialize(Url.Action("Details", "Patients"), jsonOptions));

        const setDetailsText = (id, value, fallback = "Not specified") => {
        document.getElementById(id).textContent = value || fallback;
        };

        const openAppointmentDetails = async appointmentUid => {
        detailsLoading.classList.remove("d-none");
        detailsError.classList.add("d-none");
        detailsContent.classList.add("d-none");
        openChartButton.classList.add("d-none");
        detailsModal.show();

        try {
        const url = new URL("/Scheduling/AppointmentDetails", window.location.origin);
        url.searchParams.set("appointmentUid", appointmentUid);
        const response = await fetch(url);
        if (!response.ok) {
        throw new Error(`Appointment details request failed: ${response.status}`);
        }

        const details = await response.json();
        const start = new Date(details.startDateTimeLocal);
        const end = new Date(details.endDateTimeLocal);
        const createdAt = new Date(details.createdAtLocal);
        setDetailsText("detailsPatient", details.patientDisplayName);
        setDetailsText("detailsChartNumber", details.chartNumber);
        setDetailsText("detailsStatus", details.status);
        setDetailsText("detailsDate", start.toLocaleDateString());
        setDetailsText("detailsStartTime", start.toLocaleTimeString([], { hour: "numeric", minute: "2-digit" }));
        setDetailsText("detailsEndTime", end.toLocaleTimeString([], { hour: "numeric", minute: "2-digit" }));
        setDetailsText("detailsPrimaryResource", details.primaryResourceName);
        setDetailsText("detailsRoom", details.roomResourceName, "No room assigned");
        setDetailsText("detailsType", details.appointmentType);
        setDetailsText("detailsReason", details.reason);
        setDetailsText("detailsNotes", details.notes);
        setDetailsText("detailsCreatedBy", details.createdByDisplayName, "System");
        setDetailsText("detailsCreatedAt", createdAt.toLocaleString());
        openChartButton.href = `${patientChartBaseUrl}?patientUid=${encodeURIComponent(details.patientUid)}`;
        openChartButton.classList.remove("d-none");
        detailsContent.classList.remove("d-none");
        } catch (error) {
        console.error(error);
        detailsError.textContent = "The appointment details could not be loaded. Please try again.";
        detailsError.classList.remove("d-none");
        } finally {
        detailsLoading.classList.add("d-none");
        }
        };

        const localInputValue = date => {
        const pad = value => String(value).padStart(2, "0");
        return `${date.getFullYear()}-${pad(date.getMonth() + 1)}-${pad(date.getDate())}T${pad(date.getHours())}:${pad(date.getMinutes())}`;
        };

        document.getElementById("keepCurrentTimeButton").addEventListener("click", async () => {
        pendingMove = null;
        moveAppointmentModal.hide();
        await refreshCalendar();
        });

        confirmMoveButton.addEventListener("click", async () => {
        if (!pendingMove) return;
        confirmMoveButton.disabled = true;
        moveAppointmentMessage.classList.add("d-none");
        try {
        const formData = new FormData();
        formData.append("AppointmentUid", pendingMove.appointmentUid);
        formData.append("PrimaryResourceUid", pendingMove.primaryResourceUid);
        if (pendingMove.roomResourceUid) formData.append("RoomResourceUid", pendingMove.roomResourceUid);
        formData.append("StartDateTimeLocal", localInputValue(pendingMove.startDateTimeLocal));
        formData.append("EndDateTimeLocal", localInputValue(pendingMove.endDateTimeLocal));
        const token = document.querySelector('#schedulingAntiforgeryForm input[name="__RequestVerificationToken"]').value;
        const response = await fetch("/Scheduling/RescheduleAppointment", {
        method: "POST",
        headers: { "RequestVerificationToken": token },
        body: formData
        });
        const result = await response.json().catch(() => ({}));
        if (!response.ok || !result.success) {
        moveAppointmentMessage.textContent = result.message || "The appointment could not be moved. Please try again.";
        moveAppointmentMessage.classList.remove("d-none");
        await refreshCalendar();
        return;
        }
        pendingMove = null;
        moveAppointmentModal.hide();
        await refreshCalendar();
        } catch (error) {
        console.error(error);
        moveAppointmentMessage.textContent = "The appointment could not be moved. Please try again.";
        moveAppointmentMessage.classList.remove("d-none");
        await refreshCalendar();
        } finally {
        confirmMoveButton.disabled = false;
        }
        });

        moveAppointmentModalElement.addEventListener("hidden.bs.modal", () => {
        if (pendingMove) {
        pendingMove = null;
        refreshCalendar();
        }
        });

        const refreshResourcePickerList = () => {
        const searchTerm = resourcePickerSearch.value.trim().toLocaleLowerCase();
        const matchingResources = resources.filter(resource =>
        (!selectedResourceType || resource.resourceType === selectedResourceType) &&
        (!searchTerm || resource.displayName.toLocaleLowerCase().includes(searchTerm)));
        resourcePickerList.replaceChildren();
        if (!matchingResources.length) {
        const empty = document.createElement("div");
        empty.className = "list-group-item text-body-secondary";
        empty.textContent = "No resources match the current search.";
        resourcePickerList.appendChild(empty);
        return;
        }

        matchingResources.forEach(resource => {
        const label = document.createElement("label");
        label.className = "list-group-item resource-picker-item";
        const left = document.createElement("span");
        left.className = "d-flex align-items-center gap-2";
        const checkbox = document.createElement("input");
        checkbox.type = "checkbox";
        checkbox.className = "form-check-input mt-0";
        checkbox.checked = pendingResourceUids.has(resource.resourceUid);
        checkbox.addEventListener("change", () => {
        if (checkbox.checked) pendingResourceUids.add(resource.resourceUid);
        else pendingResourceUids.delete(resource.resourceUid);
        });
        const name = document.createElement("span");
        name.textContent = resource.displayName;
        const type = document.createElement("span");
        type.className = "badge text-bg-light";
        type.textContent = resource.resourceType;
        left.append(checkbox, name);
        label.append(left, type);
        resourcePickerList.appendChild(label);
        });
        };

        document.getElementById("openResourcePickerButton").addEventListener("click", () => {
        pendingResourceUids = new Set(selectedResourceUids);
        resourcePickerSearch.value = "";
        refreshResourcePickerList();
        resourcePickerModal.show();
        });
        resourcePickerSearch.addEventListener("input", refreshResourcePickerList);
        document.getElementById("applyResourceSelectionButton").addEventListener("click", async () => {
        selectedResourceUids = new Set(pendingResourceUids);
        resourcePickerModal.hide();
        await refreshCalendar();
        });
        document.getElementById("clearResourceSelectionButton").addEventListener("click", async () => {
        selectedResourceUids.clear();
        pendingResourceUids.clear();
        resourcePickerSearch.value = "";
        resourcePickerModal.hide();
        await refreshCalendar();
        });

        const openAppointmentModal = (start, resourceUid) => {
        appointmentForm.reset();
        clearAppointmentErrors();
        document.getElementById("PatientUid").value = "";
        selectedPatientLabel.textContent = "No patient selected.";
        searchResults.replaceChildren();
        const startDate = start.toDateLocal();
        const endDate = new Date(startDate.getTime() + 15 * 60000);
        document.getElementById("StartDateTimeLocal").value = localInputValue(startDate);
        document.getElementById("EndDateTimeLocal").value = localInputValue(endDate);
        const clickedResource = resources.find(resource => resource.resourceUid === resourceUid);
        const firstVisibleProvider = getFilteredResources().find(resource => resource.resourceType === "Provider");
        const firstProvider = resources.find(resource => resource.resourceType === "Provider");
        document.getElementById("PrimaryResourceUid").value =
        clickedResource?.resourceType === "Provider"
        ? resourceUid
        : firstVisibleProvider?.resourceUid || firstProvider?.resourceUid || "";
        if (clickedResource?.resourceType === "Room") {
        document.getElementById("RoomResourceUid").value = resourceUid;
        }
        appointmentModal.show();
        };

        const clearAppointmentErrors = () => {
        appointmentMessage.className = "alert d-none";
        appointmentMessage.textContent = "";
        appointmentForm.querySelectorAll(".is-invalid").forEach(element => element.classList.remove("is-invalid"));
        appointmentForm.querySelectorAll("[data-error-for]").forEach(element => element.textContent = "");
        };

        const showMessage = (message, style = "danger") => {
        appointmentMessage.className = `alert alert-${style}`;
        appointmentMessage.textContent = message;
        };

        const searchPatients = async () => {
        const term = document.getElementById("patientSearchTerm").value.trim();
        searchResults.replaceChildren();
        if (term.length < 2) {
        showMessage("Enter at least two characters to search for a patient.");
        return;
        }
        clearAppointmentErrors();
        const response = await fetch(`/Scheduling/SearchPatients?term=${encodeURIComponent(term)}`);
        if (!response.ok) {
        showMessage("Patient search is unavailable. Please try again.");
        return;
        }
        const patients = await response.json();
        if (!patients.length) {
        searchResults.innerHTML = '<div class="list-group-item text-body-secondary">No patients found.</div>';
        return;
        }
        patients.forEach(patient => {
        const button = document.createElement("button");
        button.type = "button";
        button.className = "list-group-item list-group-item-action";
        button.textContent = `${patient.displayName} — ${patient.chartNumber}${patient.dateOfBirth ? ` — DOB ${patient.dateOfBirth}` : ""}`;
        button.addEventListener("click", () => {
        document.getElementById("PatientUid").value = patient.patientUid;
        selectedPatientLabel.textContent = `${patient.displayName} (${patient.chartNumber})`;
        searchResults.replaceChildren();
        });
        searchResults.appendChild(button);
        });
        };

        document.getElementById("patientSearchButton").addEventListener("click", searchPatients);
        document.getElementById("patientSearchTerm").addEventListener("keydown", event => {
        if (event.key === "Enter") { event.preventDefault(); searchPatients(); }
        });

        document.getElementById("saveAppointmentButton").addEventListener("click", async event => {
        clearAppointmentErrors();
        const button = event.currentTarget;
        button.disabled = true;
        try {
        const formData = new FormData(appointmentForm);
        const token = document.querySelector('#schedulingAntiforgeryForm input[name="__RequestVerificationToken"]').value;
        const response = await fetch("/Scheduling/CreateAppointment", {
        method: "POST",
        headers: { "RequestVerificationToken": token },
        body: formData
        });
        const result = await response.json();
        if (!response.ok || !result.success) {
        showMessage(result.message || "The appointment could not be saved.");
        Object.entries(result.errors || {}).forEach(([name, messages]) => {
        const input = document.getElementById(name);
        if (input) input.classList.add("is-invalid");
        const feedback = appointmentForm.querySelector(`[data-error-for="${name}"]`);
        if (feedback) feedback.textContent = messages.join(" ");
        });
        return;
        }
        appointmentModal.hide();
        appointmentForm.reset();
        await refreshCalendar();
        } catch (error) {
        console.error(error);
        showMessage("The appointment could not be saved. Please try again.");
        } finally {
        button.disabled = false;
        }
        });

        const setDateLabel = () => {
        dateLabel.textContent =
        selectedDate.toDateLocal().toLocaleDateString(
        undefined,
        {
        weekday: "long",
        month: "short",
        day: "numeric",
        year: "numeric"
        });
        };

        const dayRange = () => {
        const start = selectedDate.toDateLocal();
        start.setHours(0, 0, 0, 0);

        const end = new Date(start);
        end.setDate(end.getDate() + 1);

        return {
        start: start.toISOString(),
        end: end.toISOString()
        };
        };

        const loadEvents = async () => {
        const range = dayRange();
        const url = new URL(
        "/Scheduling/Events",
        window.location.origin);

        url.searchParams.set("start", range.start);
        url.searchParams.set("end", range.end);

        const response = await fetch(url);

        if (!response.ok) {
        throw new Error(
        `Scheduling events request failed: ${response.status}`);
        }

        const events = await response.json();
        const visibleResourceUids = new Set(getFilteredResources().map(resource => resource.resourceUid));
        return events.filter(event => visibleResourceUids.has(event.resource));
        };

        const refreshCalendar = async () => {
        setDateLabel();
        updateResourceFilterSummary();

        calendar.update({
        startDate: selectedDate,
        columns: toColumns(),
        events: []
        });

        try {
        const events = await loadEvents();

        calendar.update({
        events
        });
        } catch (error) {
        console.error(error);
        calendar.update({
        events: []
        });
        }
        };

        const dateKey = date => {
        const pad = value => String(value).padStart(2, "0");
        return `${date.getFullYear()}-${pad(date.getMonth() + 1)}-${pad(date.getDate())}`;
        };

        const refreshMonthView = async () => {
        const year = selectedMonthDate.getFullYear();
        const month = selectedMonthDate.getMonth();
        const monthStart = new Date(year, month, 1);
        const monthEnd = new Date(year, month + 1, 1);
        monthLabel.textContent = monthStart.toLocaleDateString(undefined, { month: "long", year: "numeric" });
        monthMessage.classList.add("d-none");
        monthGrid.replaceChildren();

        ["Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat"].forEach(dayName => {
        const header = document.createElement("div");
        header.className = "scheduling-month-header";
        header.textContent = dayName;
        monthGrid.appendChild(header);
        });

        for (let index = 0; index < monthStart.getDay(); index++) {
        const blank = document.createElement("div");
        blank.className = "scheduling-month-blank";
        blank.setAttribute("aria-hidden", "true");
        monthGrid.appendChild(blank);
        }

        let summaryByDate = new Map();
        try {
        const url = new URL("/Scheduling/MonthSummary", window.location.origin);
        url.searchParams.set("start", monthStart.toISOString());
        url.searchParams.set("end", monthEnd.toISOString());
        const response = await fetch(url);
        if (!response.ok) throw new Error(`Month summary request failed: ${response.status}`);
        const summary = await response.json();
        summaryByDate = new Map(summary.map(item => [String(item.date).slice(0, 10), item]));
        } catch (error) {
        console.error(error);
        monthMessage.textContent = "The month appointment summary could not be loaded. Please try again.";
        monthMessage.classList.remove("d-none");
        }

        const todayKey = dateKey(new Date());
        const selectedKey = selectedDate.toString("yyyy-MM-dd");
        const daysInMonth = new Date(year, month + 1, 0).getDate();
        for (let day = 1; day <= daysInMonth; day++) {
        const date = new Date(year, month, day);
        const key = dateKey(date);
        const item = summaryByDate.get(key);
        const count = item?.appointmentCount || 0;
        const status = item?.status || "No appointments";
        const cell = document.createElement("button");
        cell.type = "button";
        cell.className = "scheduling-month-day";
        if (key === todayKey) cell.classList.add("is-today");
        if (key === selectedKey) cell.classList.add("is-selected");
        cell.innerHTML = `<div class="scheduling-month-day-number">${day}</div>` +
        `<div class="scheduling-month-day-summary">${count} ${count === 1 ? "appointment" : "appointments"}<br>${status}</div>`;
        cell.addEventListener("click", async () => {
        selectedDate = new DayPilot.Date(key);
        selectedMonthDate = date;
        await showDayView();
        });
        monthGrid.appendChild(cell);
        }
        };

        const showDayView = async () => {
        currentView = "day";
        monthView.classList.add("d-none");
        dayView.classList.remove("d-none");
        dayViewButton.className = "btn btn-primary";
        dayViewButton.setAttribute("aria-pressed", "true");
        monthViewButton.className = "btn btn-outline-secondary";
        monthViewButton.setAttribute("aria-pressed", "false");
        viewTitle.textContent = "Day View";
        await refreshCalendar();
        };

        const showMonthView = async () => {
        currentView = "month";
        selectedMonthDate = selectedDate.toDateLocal();
        selectedMonthDate.setDate(1);
        dayView.classList.add("d-none");
        monthView.classList.remove("d-none");
        monthViewButton.className = "btn btn-primary";
        monthViewButton.setAttribute("aria-pressed", "true");
        dayViewButton.className = "btn btn-outline-secondary";
        dayViewButton.setAttribute("aria-pressed", "false");
        viewTitle.textContent = "Month View";
        await refreshMonthView();
        };

        document
        .getElementById("schedulingPreviousButton")
        .addEventListener("click", async () => {
        selectedDate = selectedDate.addDays(-1);
        await refreshCalendar();
        });

        document
        .getElementById("schedulingTodayButton")
        .addEventListener("click", async () => {
        selectedDate = DayPilot.Date.today();
        await refreshCalendar();
        });

        document
        .getElementById("schedulingNextButton")
        .addEventListener("click", async () => {
        selectedDate = selectedDate.addDays(1);
        await refreshCalendar();
        });

        resourceTypeFilter.addEventListener("change", async () => {
        selectedResourceType = resourceTypeFilter.value;
        refreshResourcePickerList();
        await refreshCalendar();
        });

        monthViewButton.addEventListener("click", showMonthView);
        dayViewButton.addEventListener("click", showDayView);
        document.getElementById("schedulingPreviousMonthButton").addEventListener("click", async () => {
        selectedMonthDate = new Date(selectedMonthDate.getFullYear(), selectedMonthDate.getMonth() - 1, 1);
        await refreshMonthView();
        });
        document.getElementById("schedulingMonthTodayButton").addEventListener("click", async () => {
        selectedMonthDate = new Date();
        selectedMonthDate.setDate(1);
        await refreshMonthView();
        });
        document.getElementById("schedulingNextMonthButton").addEventListener("click", async () => {
        selectedMonthDate = new Date(selectedMonthDate.getFullYear(), selectedMonthDate.getMonth() + 1, 1);
        await refreshMonthView();
        });

        refreshCalendar();
        });
    </script>
}
