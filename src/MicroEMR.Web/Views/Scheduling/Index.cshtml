@model MicroEMR.Web.Models.Scheduling.SchedulingIndexViewModel
@using System.Text.Json
@using System.Text.Json.Serialization

@{
    Layout = "_AppLayout";
    ViewData["Title"] = "Scheduling";
    ViewData["Subtitle"] = "Resource schedule";

    var jsonOptions = new JsonSerializerOptions
    {
        PropertyNamingPolicy = JsonNamingPolicy.CamelCase
    };

    jsonOptions.Converters.Add(new JsonStringEnumConverter());

    var resourcesJson =
        JsonSerializer.Serialize(Model.Resources, jsonOptions);
}

@section Styles {
    <style>
        .scheduling-toolbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: .75rem;
            flex-wrap: wrap;
            margin-bottom: .75rem;
        }

        .scheduling-view-bar h2 {
            margin: 0;
        }

        .scheduling-view-bar .small {
            margin: 0;
        }



        .scheduling-view-bar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: .75rem;
            flex-wrap: wrap;
            margin-bottom: .5rem;
        }

        .scheduling-toolbar-actions {
            display: flex;
            align-items: center;
            gap: .5rem;
            flex-wrap: wrap;
        }

        .scheduling-date-label {
            min-width: 12rem;
            font-weight: 600;
            text-align: center;
        }

        .scheduling-filter {
            display: flex;
            align-items: center;
            gap: .5rem;
            width: auto;
        }

        .scheduling-filter .form-label {
            margin: 0;
            white-space: nowrap;
        }

        .scheduling-calendar-shell {
            height: 640px;
            max-height: calc(100vh - var(--topbar-height) - 52px - 52px - 180px);

            border: 1px solid var(--bs-border-color);
            background: var(--bs-body-bg);
            overflow: hidden;
        }

        .scheduling-filter .form-select {
            width: 18rem;
        }

        .scheduling-filter-panel {
            display: flex;
            align-items: end;
            justify-content: flex-end;
            gap: .75rem;
            flex-wrap: wrap;
        }

        .scheduling-filter-field { min-width: 10rem; }
        .scheduling-filter-field .form-select { width: auto; min-width: 10rem; }
        .scheduling-filter-summary {
            color: var(--bs-secondary-color);
            font-size: .875rem;
            padding-bottom: .4rem;
        }

        .resource-picker-list { max-height: 24rem; overflow-y: auto; }
        .resource-picker-item {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: .75rem;
        }

        #schedulingCalendar {
            height: 100%;
        }

        .scheduling-empty-state {
            padding: 2rem;
            border: 1px dashed var(--bs-border-color);
            background: var(--bs-tertiary-bg);
            color: var(--bs-secondary-color);
        }

        .scheduling-month-toolbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: .75rem;
            flex-wrap: wrap;
            margin-bottom: .75rem;
        }

        .scheduling-month-grid {
            display: grid;
            grid-template-columns: repeat(7, minmax(0, 1fr));
            gap: .5rem;
        }

        .scheduling-month-header {
            font-size: .8rem;
            font-weight: 600;
            color: var(--bs-secondary-color);
            text-align: center;
        }

        .scheduling-month-day {
            min-height: 6.5rem;
            padding: .5rem;
            border: 1px solid var(--bs-border-color);
            border-radius: .5rem;
            background: var(--bs-body-bg);
            cursor: pointer;
            text-align: left;
        }

        .scheduling-month-day:hover { background: var(--bs-tertiary-bg); }
        .scheduling-month-day.is-today { border-color: var(--bs-primary); }
        .scheduling-month-day.is-selected { box-shadow: 0 0 0 .15rem rgba(13, 110, 253, .15); }
        .scheduling-month-day-number { font-weight: 600; }
        .scheduling-month-day-summary { margin-top: .5rem; font-size: .85rem; }
        .scheduling-month-blank { min-height: 6.5rem; }
    </style>
}

