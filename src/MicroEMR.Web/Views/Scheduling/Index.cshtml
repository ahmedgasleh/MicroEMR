@if (TempData["Error"] is string errorMessage)
{
    <div class="alert alert-warning" role="alert">
        @errorMessage
    </div>
}

<div id="schedulingActionMessage" class="alert d-none" role="alert"></div>

<div class="scheduling-view-bar">
    <div>
        <h2 class="h5 mb-2" id="schedulingViewTitle">Day View</h2>
        <div class="btn-group" role="group" aria-label="Scheduling calendar view">
            <button type="button" class="btn btn-outline-secondary" id="schedulingMonthViewButton" aria-pressed="false">
                Month
            </button>
            <button type="button" class="btn btn-primary" id="schedulingDayViewButton" aria-pressed="true">
                Day
            </button>
        </div>
    </div>

    <div class="text-body-secondary small">
        Appointment booking is available in Day View.
    </div>
</div>

<div id="schedulingMonthView" class="d-none">
    <div class="scheduling-month-toolbar">
        <div class="scheduling-toolbar-actions" aria-label="Scheduling month navigation">
            <button type="button" class="btn btn-outline-secondary" id="schedulingPreviousMonthButton">Previous Month</button>
            <button type="button" class="btn btn-outline-primary" id="schedulingMonthTodayButton">Today</button>
            <button type="button" class="btn btn-outline-secondary" id="schedulingNextMonthButton">Next Month</button>
        </div>
        <div class="scheduling-date-label" id="schedulingMonthLabel"></div>
    </div>
    <div id="schedulingMonthMessage" class="alert alert-warning d-none" role="alert"></div>
    <div class="scheduling-month-grid" id="schedulingMonthGrid" aria-label="Monthly appointment overview"></div>
</div>

<div id="schedulingDayView">
<div class="scheduling-toolbar">
    <div class="scheduling-toolbar-actions" aria-label="Scheduling date navigation">

        <button type="button" class="btn btn-outline-secondary" id="schedulingPreviousButton">
            Previous
        </button>

        <button type="button" class="btn btn-outline-primary" id="schedulingTodayButton">
            Today
        </button>

        <button type="button" class="btn btn-outline-secondary" id="schedulingNextButton">
            Next
        </button>

        <button type="button" class="btn btn-outline-danger" id="openBlockedTimeButton">
            Block Time
        </button>

        <div class="scheduling-date-label" id="schedulingDateLabel">
        </div>
    </div>

    <div class="scheduling-filter-panel">
        <div class="scheduling-filter-field">
            <label class="form-label" for="schedulingResourceTypeFilter">Resource Type</label>
            <select class="form-select" id="schedulingResourceTypeFilter">
                <option value="">All resources</option>
                <option value="Provider">Providers</option>
                <option value="Room">Rooms</option>
            </select>
        </div>
        <div class="scheduling-filter-field">
            <label class="form-label d-block">Resources</label>
            <button type="button" class="btn btn-outline-secondary" id="openResourcePickerButton">
                Select Resources
            </button>
        </div>
        <div class="scheduling-filter-summary" id="resourceFilterSummary">0 resources selected</div>
    </div>
</div>

<div id="resourceFilterMessage" class="alert alert-info d-none py-2" role="status"></div>

<div class="modal fade" id="resourcePickerModal" tabindex="-1" aria-labelledby="resourcePickerModalLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title fs-5" id="resourcePickerModalLabel">Select Scheduling Resources</h2>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <label class="form-label" for="resourcePickerSearch">Search resources</label>
                <input type="search" class="form-control mb-3" id="resourcePickerSearch"
                       placeholder="Search resources..." autocomplete="off" />
                <div class="resource-picker-list list-group" id="resourcePickerList"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-primary" id="selectAllVisibleResourcesButton">
                    Select All Visible
                </button>
                <button type="button" class="btn btn-outline-secondary" id="clearResourceSelectionButton">
                    Clear Selection
                </button>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="applyResourceSelectionButton">Apply</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="appointmentDetailsModal" tabindex="-1" aria-labelledby="appointmentDetailsModalLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title fs-5" id="appointmentDetailsModalLabel">Appointment Details</h2>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div id="appointmentDetailsLoading" class="text-center py-4">
                    <div class="spinner-border text-primary" role="status"><span class="visually-hidden">Loading</span>
                    </div>
                    <div class="mt-2">Loading appointment details...</div>
                </div>
                <div id="appointmentDetailsError" class="alert alert-danger d-none" role="alert"></div>
                <dl id="appointmentDetailsContent" class="row mb-0 d-none">
                    <dt class="col-sm-4">Patient</dt>
                    <dd class="col-sm-8" id="detailsPatient"></dd>
                    <dt class="col-sm-4">Chart number</dt>
                    <dd class="col-sm-8" id="detailsChartNumber"></dd>
                    <dt class="col-sm-4">Status</dt>
                    <dd class="col-sm-8" id="detailsStatus"></dd>
                    <dt class="col-sm-4">Date</dt>
                    <dd class="col-sm-8" id="detailsDate"></dd>
                    <dt class="col-sm-4">Start time</dt>
                    <dd class="col-sm-8" id="detailsStartTime"></dd>
                    <dt class="col-sm-4">End time</dt>
                    <dd class="col-sm-8" id="detailsEndTime"></dd>
                    <dt class="col-sm-4">Provider/resource</dt>
                    <dd class="col-sm-8" id="detailsPrimaryResource"></dd>
                    <dt class="col-sm-4">Room</dt>
                    <dd class="col-sm-8" id="detailsRoom"></dd>
                    <dt class="col-sm-4">Appointment type</dt>
                    <dd class="col-sm-8" id="detailsType"></dd>
                    <dt class="col-sm-4">Reason</dt>
                    <dd class="col-sm-8" id="detailsReason"></dd>
                    <dt class="col-sm-4">Notes</dt>
                    <dd class="col-sm-8 text-break" id="detailsNotes"></dd>
                    <dt class="col-sm-4">Created by</dt>
                    <dd class="col-sm-8" id="detailsCreatedBy"></dd>
                    <dt class="col-sm-4">Created date</dt>
                    <dd class="col-sm-8" id="detailsCreatedAt"></dd>
                </dl>
                <div id="appointmentHistoryContainer" class="d-none mt-4 pt-3 border-top">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <h3 class="fs-6 mb-0">Appointment History</h3>
                    </div>
                    <div id="appointmentHistoryLoading" class="text-center py-3 d-none">
                        <div class="spinner-border spinner-border-sm" role="status">
                            <span class="visually-hidden">Loading appointment history...</span>
                        </div>
                    </div>
                    <div id="appointmentHistoryMessage" class="alert alert-warning d-none" role="status"></div>
                    <div id="appointmentHistoryList" class="vstack gap-3"></div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary d-none" id="viewAppointmentHistoryButton">
                    View History
                </button>
                <button type="button" class="btn btn-outline-danger d-none" id="cancelAppointmentButton">
                    Cancel Appointment
                </button>
                <button type="button" class="btn btn-primary d-none" id="editAppointmentButton">
                    Edit Appointment
                </button>
                <a id="openPatientChartButton" class="btn btn-primary d-none" href="#">Open Chart</a>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="editAppointmentModal" tabindex="-1" aria-labelledby="editAppointmentModalLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title fs-5" id="editAppointmentModalLabel">Edit Appointment</h2>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div id="editAppointmentMessage" class="alert alert-danger d-none" role="alert"></div>
                <form id="editAppointmentForm" novalidate>
                    <input type="hidden" id="EditAppointmentUid" name="AppointmentUid" />
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label for="EditPrimaryResourceUid" class="form-label">Primary provider/resource</label>
                            <select id="EditPrimaryResourceUid" name="PrimaryResourceUid" class="form-select">
                                <option value="">Select provider/resource</option>
                                @foreach (var resource in Model.Resources.Where(r => r.ResourceType == "Provider")
                                    .OrderBy(r => r.SortOrder).ThenBy(r => r.DisplayName))
                                {
                                    <option value="@resource.ResourceUid">@resource.DisplayName</option>
                                }
                            </select>
                            <div class="invalid-feedback" data-edit-error-for="PrimaryResourceUid"></div>
                        </div>
                        <div class="col-md-6">
                            <label for="EditRoomResourceUid" class="form-label">Room (optional)</label>
                            <select id="EditRoomResourceUid" name="RoomResourceUid" class="form-select">
                                <option value="">No room</option>
                                @foreach (var room in Model.Resources.Where(r => r.ResourceType == "Room")
                                    .OrderBy(r => r.SortOrder).ThenBy(r => r.DisplayName))
                                {
                                    <option value="@room.ResourceUid">@room.DisplayName</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label for="EditStartDateTimeLocal" class="form-label">Start</label>
                            <input id="EditStartDateTimeLocal" name="StartDateTimeLocal" type="datetime-local"
                                   class="form-control" />
                            <div class="invalid-feedback" data-edit-error-for="StartDateTimeLocal"></div>
                        </div>
                        <div class="col-md-6">
                            <label for="EditEndDateTimeLocal" class="form-label">End</label>
                            <input id="EditEndDateTimeLocal" name="EndDateTimeLocal" type="datetime-local"
                                   class="form-control" />
                            <div class="invalid-feedback" data-edit-error-for="EndDateTimeLocal"></div>
                        </div>
                        <div class="col-md-6">
                            <label for="EditAppointmentType" class="form-label">Appointment type</label>
                            <input id="EditAppointmentType" name="AppointmentType" maxlength="100"
                                   class="form-control" />
                            <div class="invalid-feedback" data-edit-error-for="AppointmentType"></div>
                        </div>
                        <div class="col-md-6">
                            <label for="EditReason" class="form-label">Reason</label>
                            <input id="EditReason" name="Reason" maxlength="500" class="form-control" />
                            <div class="invalid-feedback" data-edit-error-for="Reason"></div>
                        </div>
                        <div class="col-12">
                            <label for="EditNotes" class="form-label">Notes</label>
                            <textarea id="EditNotes" name="Notes" maxlength="1000" rows="3"
                                      class="form-control"></textarea>
                            <div class="invalid-feedback" data-edit-error-for="Notes"></div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="saveEditAppointmentButton">Save</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="cancelAppointmentModal" tabindex="-1" aria-labelledby="cancelAppointmentModalLabel"
     aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title fs-5" id="cancelAppointmentModalLabel">Cancel Appointment</h2>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div id="cancelAppointmentMessage" class="alert alert-danger d-none" role="alert"></div>
                <p>Are you sure you want to cancel this appointment?</p>
                <label for="cancelAppointmentReason" class="form-label">Reason (optional)</label>
                <textarea id="cancelAppointmentReason" class="form-control" rows="3" maxlength="500"></textarea>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" id="keepAppointmentButton">Keep Appointment</button>
                <button type="button" class="btn btn-danger" id="confirmCancelAppointmentButton">
                    Confirm Cancel
                </button>
            </div>
        </div>
    </div>
</div>

<form id="schedulingAntiforgeryForm" class="d-none">@Html.AntiForgeryToken()</form>

<div class="modal fade" id="createBlockedTimeModal" tabindex="-1"
     aria-labelledby="createBlockedTimeModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title fs-5" id="createBlockedTimeModalLabel">Block Time</h2>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div id="createBlockedTimeMessage" class="alert alert-danger d-none" role="alert"></div>
                <form id="createBlockedTimeForm">
                    <div class="mb-3">
                        <label for="BlockedTimeResourceUid" class="form-label">Resource</label>
                        <select id="BlockedTimeResourceUid" name="ResourceUid" class="form-select">
                            @foreach (var resource in Model.Resources.OrderBy(r => r.SortOrder))
                            {
                                <option value="@resource.ResourceUid">@resource.DisplayName (@resource.ResourceType)</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label for="BlockedTimeDate" class="form-label">Date</label>
                        <input id="BlockedTimeDate" name="Date" type="date" class="form-control" />
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-6">
                            <label for="BlockedTimeStart" class="form-label">Start time</label>
                            <input id="BlockedTimeStart" name="StartTime" type="time" class="form-control" value="09:00" />
                        </div>
                        <div class="col-6">
                            <label for="BlockedTimeEnd" class="form-label">End time</label>
                            <input id="BlockedTimeEnd" name="EndTime" type="time" class="form-control" value="10:00" />
                        </div>
                    </div>
                    <label for="BlockedTimeReason" class="form-label">Reason</label>
                    <textarea id="BlockedTimeReason" name="Reason" maxlength="500" rows="3"
                              class="form-control"></textarea>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="saveBlockedTimeButton">Save Block</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="blockedTimeDetailsModal" tabindex="-1"
     aria-labelledby="blockedTimeDetailsModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title fs-5" id="blockedTimeDetailsModalLabel">Blocked Time</h2>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div id="blockedTimeDetailsMessage" class="alert alert-danger d-none" role="alert"></div>
                <dl class="row mb-0">
                    <dt class="col-4">Resource</dt><dd class="col-8" id="blockedTimeDetailsResource"></dd>
                    <dt class="col-4">Start</dt><dd class="col-8" id="blockedTimeDetailsStart"></dd>
                    <dt class="col-4">End</dt><dd class="col-8" id="blockedTimeDetailsEnd"></dd>
                    <dt class="col-4">Reason</dt><dd class="col-8" id="blockedTimeDetailsReason"></dd>
                </dl>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-danger" id="removeBlockedTimeButton">Remove Block</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="moveAppointmentModal" tabindex="-1" aria-labelledby="moveAppointmentModalLabel"
     aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title fs-5" id="moveAppointmentModalLabel">Confirm Appointment Move</h2>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div id="moveAppointmentMessage" class="alert alert-danger d-none" role="alert"></div>
                <p class="mb-0" id="moveAppointmentSummary"></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" id="keepCurrentTimeButton">Keep Current Time</button>
                <button type="button" class="btn btn-primary" id="confirmMoveButton">Confirm Move</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="addAppointmentModal" tabindex="-1" aria-labelledby="addAppointmentModalLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title fs-5" id="addAppointmentModalLabel">Add Appointment</h2>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div id="appointmentMessage" class="alert d-none" role="alert"></div>
                <form id="addAppointmentForm" novalidate>
                    <input type="hidden" id="PatientUid" name="PatientUid" />
                    <div class="mb-3 patient-search-container">
                        <label for="patientSearchTerm" class="form-label">Patient</label>
                        <div class="input-group">
                            <input id="patientSearchTerm" class="form-control" autocomplete="off"
                                   placeholder="Name or chart number" />
                            <button id="patientSearchButton" class="btn btn-outline-primary"
                                    type="button">Search</button>
                        </div>
                        <div id="patientSearchResults" class="patient-search-dropdown d-none"></div>
                        <div id="selectedPatientLabel" class="form-text">No patient selected.</div>
                        <div class="invalid-feedback" data-error-for="PatientUid"></div>
                    </div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label for="PrimaryResourceUid" class="form-label">Primary resource</label>
                            <select id="PrimaryResourceUid" name="PrimaryResourceUid" class="form-select">
                                <option value="">Select resource</option>
                                @foreach (var resource in Model.Resources.OrderBy(r => r.ResourceType == "Provider" ? 0
                                : 1).ThenBy(r => r.SortOrder))
                                {
                                    <option value="@resource.ResourceUid">@resource.DisplayName (@resource.ResourceType)
                                    </option>
                                }
                            </select>
                            <div class="invalid-feedback" data-error-for="PrimaryResourceUid"></div>
                        </div>
                        <div class="col-md-6">
                            <label for="RoomResourceUid" class="form-label">Room (optional)</label>
                            <select id="RoomResourceUid" name="RoomResourceUid" class="form-select">
                                <option value="">No room</option>
                                @foreach (var room in Model.Resources.Where(r => r.ResourceType == "Room").OrderBy(r =>
                                r.SortOrder))
                                {
                                    <option value="@room.ResourceUid">@room.DisplayName</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label for="StartDateTimeLocal" class="form-label">Start</label>
                            <input id="StartDateTimeLocal" name="StartDateTimeLocal" type="datetime-local"
                                   class="form-control" />
                            <div class="invalid-feedback" data-error-for="StartDateTimeLocal"></div>
                        </div>
                        <div class="col-md-6">
                            <label for="EndDateTimeLocal" class="form-label">End</label>
                            <input id="EndDateTimeLocal" name="EndDateTimeLocal" type="datetime-local"
                                   class="form-control" />
                            <div class="invalid-feedback" data-error-for="EndDateTimeLocal"></div>
                        </div>
                        <div class="col-md-6">
                            <label for="AppointmentType" class="form-label">Appointment type</label>
                            <select id="AppointmentType" name="AppointmentType" class="form-select">
                                <option value="">Select type</option>
                                @foreach (var type in new[] { "Office Visit", "Phone Visit", "Virtual Visit",
             "Follow-up", "Consultation", "Procedure", "Other" })
                                {
                                    <option value="@type">@type</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label for="Reason" class="form-label">Reason</label>
                            <input id="Reason" name="Reason" maxlength="500" class="form-control" />
                            <div class="invalid-feedback" data-error-for="Reason"></div>
                        </div>
                        <div class="col-12">
                            <label for="Notes" class="form-label">Notes</label>
                            <textarea id="Notes" name="Notes" maxlength="1000" rows="3" class="form-control"></textarea>
                            <div class="invalid-feedback" data-error-for="Notes"></div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="saveAppointmentButton">Save Appointment</button>
            </div>
        </div>
    </div>
</div>

@if (Model.Resources.Count == 0)
{
    <div class="scheduling-empty-state">
        No active scheduling resources were found.
    </div>
}
else
{
    <div class="scheduling-calendar-shell">
        <div id="schedulingCalendar"></div>
    </div>
}
</div>

@section Scripts {
    <script src="~/lib/daypilot/daypilot-javascript.min.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", async () => {
        if (!window.DayPilot) {
        console.error("DayPilot Lite could not be loaded.");
        return;
        }

        const resources = @Html.Raw(resourcesJson);
        const initialDate = @Html.Raw(initialDateJson);
        const shouldOpenAddAppointment = @Html.Raw(openAddAppointmentJson);

        if (!resources.length) {
        return;
        }

        let selectedDate = initialDate
        ? new DayPilot.Date(initialDate)
        : DayPilot.Date.today();
        let currentView = "day";
        let selectedMonthDate = new Date();
        selectedMonthDate.setHours(0, 0, 0, 0);
        let selectedResourceType = "";
        let selectedResourceUids = new Set(
        resources.slice(0, Math.min(5, resources.length)).map(resource => resource.resourceUid));
        let pendingResourceUids = new Set();
        let blockedTimes = [];
        const resourceTypeFilter = document.getElementById("schedulingResourceTypeFilter");
        const resourceFilterSummary = document.getElementById("resourceFilterSummary");
        const resourceFilterMessage = document.getElementById("resourceFilterMessage");

        const dateLabel =
        document.getElementById("schedulingDateLabel");
        const dayView = document.getElementById("schedulingDayView");
        const monthView = document.getElementById("schedulingMonthView");
        const dayViewButton = document.getElementById("schedulingDayViewButton");
        const monthViewButton = document.getElementById("schedulingMonthViewButton");
        const viewTitle = document.getElementById("schedulingViewTitle");
        const monthGrid = document.getElementById("schedulingMonthGrid");
        const monthLabel = document.getElementById("schedulingMonthLabel");
        const monthMessage = document.getElementById("schedulingMonthMessage");

        const getMatchingResources = () => resources.filter(resource =>
        (!selectedResourceType || resource.resourceType === selectedResourceType) &&
        selectedResourceUids.has(resource.resourceUid));

        const getFilteredResources = () => getMatchingResources();

        const toColumns = () => getFilteredResources()
        .map(resource => ({
        id: resource.resourceUid,
        name: resource.displayName
        }));

        const updateResourceFilterSummary = () => {
        const matchingCount = getMatchingResources().length;
        const selectedCount = selectedResourceUids.size;
        resourceFilterSummary.textContent =
        `${selectedCount} ${selectedCount === 1 ? "resource" : "resources"} selected`;
        resourceFilterMessage.classList.toggle("d-none", matchingCount > 0);
        resourceFilterMessage.textContent = selectedCount === 0
        ? "Select at least one resource to display scheduling columns."
        : "No selected resources match the selected resource type.";
        };

        const calendar = new DayPilot.Calendar(
        "schedulingCalendar",
        {
        viewType: "Resources",
        columns: toColumns(),
        startDate: selectedDate,
        cellDuration: 15,
        businessBeginsHour: 8,
        businessEndsHour: 18,
        eventMoveHandling: "Update",
        eventResizeHandling: "Disabled",
        eventDeleteHandling: "Disabled",
        timeRangeSelectedHandling: "Enabled",
        onEventMove: async args => {
        args.preventDefault();
        if (args.e.data.eventKind === "blockedTime") return;
        const destination = resources.find(resource => resource.resourceUid === args.newResource);
        if (destination?.resourceType !== "Provider") {
        await refreshCalendar();
        window.alert("Appointments can only be moved between provider columns.");
        return;
        }
        try {
        const detailsUrl = new URL("/Scheduling/AppointmentDetails", window.location.origin);
        detailsUrl.searchParams.set("appointmentUid", args.e.id());
        const detailsResponse = await fetch(detailsUrl);
        if (!detailsResponse.ok) throw new Error(`Appointment details request failed: ${detailsResponse.status}`);
        const details = await detailsResponse.json();
        pendingMove = {
        appointmentUid: args.e.id(),
        primaryResourceUid: args.newResource,
        roomResourceUid: details.roomResourceUid || null,
        startDateTimeLocal: args.newStart.toDateLocal(),
        endDateTimeLocal: args.newEnd.toDateLocal()
        };

        const start = pendingMove.startDateTimeLocal;
        const end = pendingMove.endDateTimeLocal;
        if (hasBlockedTimeConflict(pendingMove.primaryResourceUid, start, end)) {
        pendingMove = null;
        await refreshCalendar();
        window.alert("This resource is blocked during the selected time.");
        return;
        }
        moveAppointmentSummary.textContent =
        `Move to ${destination?.displayName || "the selected resource"} on ${start.toLocaleDateString()} ` +
        `from ${start.toLocaleTimeString([], { hour: "numeric", minute: "2-digit" })} ` +
        `to ${end.toLocaleTimeString([], { hour: "numeric", minute: "2-digit" })}?`;
        moveAppointmentMessage.classList.add("d-none");
        moveAppointmentMessage.textContent = "";
        moveAppointmentModal.show();
        } catch (error) {
        console.error(error);
        pendingMove = null;
        await refreshCalendar();
        window.alert("The appointment could not be prepared for rescheduling. Please try again.");
        }
        },
        onTimeRangeSelected: args => {
        openAppointmentModal(args.start, args.resource);
        calendar.clearSelection();
        },
        onEventClick: args => {
        if (args.e.data.eventKind === "blockedTime") {
        openBlockedTimeDetails(args.e.data);
        return;
        }
        openAppointmentDetails(args.e.id());
        }
        });

        calendar.init();

        const appointmentModal = new bootstrap.Modal(document.getElementById("addAppointmentModal"));
        const resourcePickerModal = new bootstrap.Modal(document.getElementById("resourcePickerModal"));
        const resourcePickerSearch = document.getElementById("resourcePickerSearch");
        const resourcePickerList = document.getElementById("resourcePickerList");
        const createBlockedTimeModal = new bootstrap.Modal(
        document.getElementById("createBlockedTimeModal"));
        const blockedTimeDetailsModal = new bootstrap.Modal(
        document.getElementById("blockedTimeDetailsModal"));
        const createBlockedTimeForm = document.getElementById("createBlockedTimeForm");
        const createBlockedTimeMessage = document.getElementById("createBlockedTimeMessage");
        const blockedTimeDetailsMessage = document.getElementById("blockedTimeDetailsMessage");
        let currentBlockedTimeUid = null;
        const moveAppointmentModalElement = document.getElementById("moveAppointmentModal");
        const moveAppointmentModal = new bootstrap.Modal(moveAppointmentModalElement);
        const moveAppointmentSummary = document.getElementById("moveAppointmentSummary");
        const moveAppointmentMessage = document.getElementById("moveAppointmentMessage");
        const confirmMoveButton = document.getElementById("confirmMoveButton");
        let pendingMove = null;
        const appointmentForm = document.getElementById("addAppointmentForm");
        const appointmentMessage = document.getElementById("appointmentMessage");
        const selectedPatientLabel = document.getElementById("selectedPatientLabel");
        const searchResults = document.getElementById("patientSearchResults");
        const hasBlockedTimeConflict = (resourceUid, start, end) => {
        const startValue = new Date(start).getTime();
        const endValue = new Date(end).getTime();
        return blockedTimes.some(block =>
        block.resourceUid === resourceUid &&
        startValue < new Date(block.endDateTimeUtc).getTime() &&
        endValue > new Date(block.startDateTimeUtc).getTime());
        };

        const openBlockedTimeDetails = eventData => {
        currentBlockedTimeUid = eventData.blockedTimeUid;
        const resource = resources.find(item => item.resourceUid === eventData.resource);
        document.getElementById("blockedTimeDetailsResource").textContent =
        resource?.displayName || "Unknown resource";
        document.getElementById("blockedTimeDetailsStart").textContent =
        new Date(eventData.start).toLocaleString();
        document.getElementById("blockedTimeDetailsEnd").textContent =
        new Date(eventData.end).toLocaleString();
        document.getElementById("blockedTimeDetailsReason").textContent =
        eventData.reason || "No reason provided";
        blockedTimeDetailsMessage.classList.add("d-none");
        blockedTimeDetailsModal.show();
        };

        document.getElementById("openBlockedTimeButton").addEventListener("click", () => {
        createBlockedTimeForm.reset();
        const date = selectedDate.toString("yyyy-MM-dd");
        document.getElementById("BlockedTimeDate").value = date;
        document.getElementById("BlockedTimeStart").value = "09:00";
        document.getElementById("BlockedTimeEnd").value = "10:00";
        const visibleResources = getFilteredResources();
        const visibleResourceUids = new Set(visibleResources.map(resource => resource.resourceUid));
        const resourceSelect = document.getElementById("BlockedTimeResourceUid");
        Array.from(resourceSelect.options).forEach(option => {
        option.hidden = !visibleResourceUids.has(option.value);
        option.disabled = option.hidden;
        });
        resourceSelect.value = visibleResources[0]?.resourceUid || "";
        createBlockedTimeMessage.classList.add("d-none");
        createBlockedTimeModal.show();
        });

        document.getElementById("saveBlockedTimeButton").addEventListener("click", async event => {
        const button = event.currentTarget;
        createBlockedTimeMessage.classList.add("d-none");
        const resourceUid = document.getElementById("BlockedTimeResourceUid").value;
        const dateValue = document.getElementById("BlockedTimeDate").value;
        const startTimeValue = document.getElementById("BlockedTimeStart").value;
        const endTimeValue = document.getElementById("BlockedTimeEnd").value;
        if (!resourceUid) {
        createBlockedTimeMessage.textContent = "Please select a resource.";
        createBlockedTimeMessage.classList.remove("d-none");
        return;
        }
        if (!dateValue || !startTimeValue || !endTimeValue) {
        createBlockedTimeMessage.textContent = "Please enter a valid date, start time, and end time.";
        createBlockedTimeMessage.classList.remove("d-none");
        return;
        }
        const startLocal = new Date(`${dateValue}T${startTimeValue}`);
        const endLocal = new Date(`${dateValue}T${endTimeValue}`);
        if (!Number.isFinite(startLocal.getTime()) || !Number.isFinite(endLocal.getTime())) {
        createBlockedTimeMessage.textContent = "Please enter a valid date, start time, and end time.";
        createBlockedTimeMessage.classList.remove("d-none");
        return;
        }
        if (endLocal <= startLocal) {
        createBlockedTimeMessage.textContent = "End time must be after start time.";
        createBlockedTimeMessage.classList.remove("d-none");
        return;
        }
        button.disabled = true;
        try {
        const token = document.querySelector(
        '#schedulingAntiforgeryForm input[name="__RequestVerificationToken"]').value;
        const formData = new FormData();
        formData.append("ResourceUid", resourceUid);
        formData.append("Date", dateValue);
        formData.append("StartTime", startTimeValue);
        formData.append("EndTime", endTimeValue);
        formData.append("Reason", document.getElementById("BlockedTimeReason").value || "");
        formData.append("__RequestVerificationToken", token);
        const response = await fetch("/Scheduling/CreateBlockedTime", {
        method: "POST", body: formData
        });
        const result = await response.json().catch(() => ({}));
        if (!response.ok || !result.success) {
        throw new Error(result.message || "Blocked time could not be created.");
        }
        createBlockedTimeModal.hide();
        await refreshCalendar();
        showSchedulingActionMessage(result.message || "Blocked time created.", "success");
        } catch (error) {
        createBlockedTimeMessage.textContent = error instanceof Error
        ? error.message : "Blocked time could not be created.";
        createBlockedTimeMessage.classList.remove("d-none");
        } finally {
        button.disabled = false;
        }
        });

        document.getElementById("removeBlockedTimeButton").addEventListener("click", async event => {
        if (!currentBlockedTimeUid) return;
        const button = event.currentTarget;
        button.disabled = true;
        blockedTimeDetailsMessage.classList.add("d-none");
        try {
        const formData = new FormData();
        formData.append("blockedTimeUid", currentBlockedTimeUid);
        const token = document.querySelector(
        '#schedulingAntiforgeryForm input[name="__RequestVerificationToken"]').value;
        const response = await fetch("/Scheduling/CancelBlockedTime", {
        method: "POST", headers: { "RequestVerificationToken": token }, body: formData
        });
        const result = await response.json().catch(() => ({}));
        if (!response.ok || !result.success) {
        throw new Error(result.message || "Blocked time could not be removed.");
        }
        currentBlockedTimeUid = null;
        blockedTimeDetailsModal.hide();
        await refreshCalendar();
        showSchedulingActionMessage(result.message || "Blocked time removed.", "success");
        } catch (error) {
        blockedTimeDetailsMessage.textContent = error instanceof Error
        ? error.message : "Blocked time could not be removed.";
        blockedTimeDetailsMessage.classList.remove("d-none");
        } finally {
        button.disabled = false;
        }
        });
        const hidePatientSearchResults = () => {
        searchResults.classList.add("d-none");
        searchResults.replaceChildren();
        };
        const showPatientSearchResults = () => searchResults.classList.remove("d-none");
        const appointmentDetailsModalElement = document.getElementById("appointmentDetailsModal");
        const detailsModal = new bootstrap.Modal(appointmentDetailsModalElement);
        const detailsLoading = document.getElementById("appointmentDetailsLoading");
        const detailsError = document.getElementById("appointmentDetailsError");
        const detailsContent = document.getElementById("appointmentDetailsContent");
        const openChartButton = document.getElementById("openPatientChartButton");
        const cancelAppointmentButton = document.getElementById("cancelAppointmentButton");
        const editAppointmentButton = document.getElementById("editAppointmentButton");
        const viewAppointmentHistoryButton = document.getElementById("viewAppointmentHistoryButton");
        const appointmentHistoryContainer = document.getElementById("appointmentHistoryContainer");
        const appointmentHistoryLoading = document.getElementById("appointmentHistoryLoading");
        const appointmentHistoryMessage = document.getElementById("appointmentHistoryMessage");
        const appointmentHistoryList = document.getElementById("appointmentHistoryList");
        const editAppointmentModalElement = document.getElementById("editAppointmentModal");
        const editAppointmentModal = new bootstrap.Modal(editAppointmentModalElement);
        const editAppointmentForm = document.getElementById("editAppointmentForm");
        const editAppointmentMessage = document.getElementById("editAppointmentMessage");
        const saveEditAppointmentButton = document.getElementById("saveEditAppointmentButton");
        const cancelAppointmentModalElement = document.getElementById("cancelAppointmentModal");
        const cancelAppointmentModal = new bootstrap.Modal(cancelAppointmentModalElement);
        const cancelAppointmentReason = document.getElementById("cancelAppointmentReason");
        const cancelAppointmentMessage = document.getElementById("cancelAppointmentMessage");
        const confirmCancelAppointmentButton = document.getElementById("confirmCancelAppointmentButton");
        const schedulingActionMessage = document.getElementById("schedulingActionMessage");
        const cancelAppointmentUrl = @Html.Raw(JsonSerializer.Serialize(Url.Action("CancelAppointment", "Scheduling"), jsonOptions));
        const updateAppointmentUrl = @Html.Raw(JsonSerializer.Serialize(Url.Action("UpdateAppointment", "Scheduling"), jsonOptions));
        const appointmentHistoryUrl = @Html.Raw(JsonSerializer.Serialize(Url.Action("AppointmentHistory", "Scheduling"), jsonOptions));
        const patientChartBaseUrl = @Html.Raw(JsonSerializer.Serialize(Url.Action("Details", "Patients"), jsonOptions));
        let currentAppointmentUid = null;
        let currentAppointmentDetails = null;

        const showSchedulingActionMessage = (message, type) => {
        schedulingActionMessage.className = `alert alert-${type}`;
        schedulingActionMessage.textContent = message;
        };

        const setDetailsText = (id, value, fallback = "Not specified") => {
        document.getElementById(id).textContent = value || fallback;
        };

        const openAppointmentDetails = async appointmentUid => {
        currentAppointmentUid = null;
        currentAppointmentDetails = null;
        detailsLoading.classList.remove("d-none");
        detailsError.classList.add("d-none");
        detailsContent.classList.add("d-none");
        openChartButton.classList.add("d-none");
        cancelAppointmentButton.classList.add("d-none");
        editAppointmentButton.classList.add("d-none");
        viewAppointmentHistoryButton.classList.add("d-none");
        appointmentHistoryContainer.classList.add("d-none");
        appointmentHistoryList.replaceChildren();
        appointmentHistoryMessage.classList.add("d-none");
        viewAppointmentHistoryButton.textContent = "View History";
        detailsModal.show();

        try {
        const url = new URL("/Scheduling/AppointmentDetails", window.location.origin);
        url.searchParams.set("appointmentUid", appointmentUid);
        const response = await fetch(url);
        if (!response.ok) {
        throw new Error(`Appointment details request failed: ${response.status}`);
        }

        const details = await response.json();
        currentAppointmentUid = details.appointmentUid;
        currentAppointmentDetails = details;
        const start = new Date(details.startDateTimeLocal);
        const end = new Date(details.endDateTimeLocal);
        const createdAt = new Date(details.createdAtLocal);
        setDetailsText("detailsPatient", details.patientDisplayName);
        setDetailsText("detailsChartNumber", details.chartNumber);
        setDetailsText("detailsStatus", details.status);
        setDetailsText("detailsDate", start.toLocaleDateString());
        setDetailsText("detailsStartTime", start.toLocaleTimeString([], { hour: "numeric", minute: "2-digit" }));
        setDetailsText("detailsEndTime", end.toLocaleTimeString([], { hour: "numeric", minute: "2-digit" }));
        setDetailsText("detailsPrimaryResource", details.primaryResourceName);
        setDetailsText("detailsRoom", details.roomResourceName, "No room assigned");
        setDetailsText("detailsType", details.appointmentType);
        setDetailsText("detailsReason", details.reason);
        setDetailsText("detailsNotes", details.notes);
        setDetailsText("detailsCreatedBy", details.createdByDisplayName, "System");
        setDetailsText("detailsCreatedAt", createdAt.toLocaleString());
        openChartButton.href = `${patientChartBaseUrl}?patientUid=${encodeURIComponent(details.patientUid)}`;
        openChartButton.classList.remove("d-none");
        cancelAppointmentButton.classList.toggle(
        "d-none",
        String(details.status).toLowerCase() === "cancelled");
        editAppointmentButton.classList.toggle(
        "d-none",
        String(details.status).toLowerCase() === "cancelled");
        viewAppointmentHistoryButton.classList.remove("d-none");
        detailsContent.classList.remove("d-none");
        } catch (error) {
        console.error(error);
        detailsError.textContent = "The appointment details could not be loaded. Please try again.";
        detailsError.classList.remove("d-none");
        } finally {
        detailsLoading.classList.add("d-none");
        }
        };

        const formatHistoryDate = value => value
        ? new Intl.DateTimeFormat(undefined, {
        dateStyle: "medium",
        timeStyle: "short"
        }).format(new Date(value))
        : null;

        const appendHistoryDetail = (container, text) => {
        if (!text) return;
        const detail = document.createElement("div");
        detail.className = "small text-body-secondary";
        detail.textContent = text;
        container.appendChild(detail);
        };

        const renderAppointmentHistory = history => {
        appointmentHistoryList.replaceChildren();

        history.forEach(item => {
        const entry = document.createElement("div");
        entry.className = "border-start border-3 border-primary ps-3";

        const title = document.createElement("div");
        title.className = "fw-semibold";
        title.textContent = item.actionType || "Appointment updated";
        entry.appendChild(title);

        appendHistoryDetail(entry, item.actionDescription);

        if (item.oldStatus || item.newStatus) {
        appendHistoryDetail(
        entry,
        `${item.oldStatus || "Not set"} → ${item.newStatus || "Not set"}`);
        }

        if (item.oldStartDateTimeUtc || item.newStartDateTimeUtc) {
        appendHistoryDetail(
        entry,
        `Time: ${formatHistoryDate(item.oldStartDateTimeUtc) || "Not set"} → ` +
        `${formatHistoryDate(item.newStartDateTimeUtc) || "Not set"}`);
        }

        if (item.oldResourceUid || item.newResourceUid) {
        appendHistoryDetail(entry, "Provider/resource assignment changed.");
        }

        if (item.reason) {
        appendHistoryDetail(entry, `Reason: ${item.reason}`);
        }

        appendHistoryDetail(
        entry,
        `${formatHistoryDate(item.createdAt) || ""}` +
        `${item.createdByDisplayName ? ` · ${item.createdByDisplayName}` : ""}`);

        appointmentHistoryList.appendChild(entry);
        });
        };

        viewAppointmentHistoryButton.addEventListener("click", async () => {
        if (!appointmentHistoryContainer.classList.contains("d-none")) {
        appointmentHistoryContainer.classList.add("d-none");
        viewAppointmentHistoryButton.textContent = "View History";
        return;
        }

        if (!currentAppointmentUid) return;

        appointmentHistoryContainer.classList.remove("d-none");
        viewAppointmentHistoryButton.textContent = "Hide History";
        appointmentHistoryLoading.classList.remove("d-none");
        appointmentHistoryMessage.classList.add("d-none");
        appointmentHistoryList.replaceChildren();

        try {
        const url = new URL(appointmentHistoryUrl, window.location.origin);
        url.searchParams.set("appointmentUid", currentAppointmentUid);
        const response = await fetch(url, {
        headers: { "Accept": "application/json" }
        });
        const result = await response.json().catch(() => ({}));

        if (!response.ok || !result.success) {
        throw new Error(result.message || "Appointment history could not be loaded.");
        }

        if (!result.history?.length) {
        appointmentHistoryMessage.textContent = "No appointment history is available.";
        appointmentHistoryMessage.classList.remove("d-none");
        return;
        }

        renderAppointmentHistory(result.history);
        } catch (error) {
        console.error(error);
        appointmentHistoryMessage.textContent =
        error instanceof Error
        ? error.message
        : "Appointment history could not be loaded.";
        appointmentHistoryMessage.classList.remove("d-none");
        } finally {
        appointmentHistoryLoading.classList.add("d-none");
        }
        });

        const clearEditAppointmentErrors = () => {
        editAppointmentMessage.classList.add("d-none");
        editAppointmentMessage.textContent = "";
        editAppointmentForm.querySelectorAll(".is-invalid").forEach(element =>
        element.classList.remove("is-invalid"));
        editAppointmentForm.querySelectorAll("[data-edit-error-for]").forEach(element =>
        element.textContent = "");
        };

        const showEditAppointmentErrors = errors => {
        if (!errors) return;
        Object.entries(errors).forEach(([field, messages]) => {
        const input = editAppointmentForm.elements.namedItem(field);
        const feedback = editAppointmentForm.querySelector(`[data-edit-error-for="${field}"]`);
        if (input) input.classList.add("is-invalid");
        if (feedback) feedback.textContent = Array.isArray(messages) ? messages[0] : messages;
        });
        };

        editAppointmentButton.addEventListener("click", () => {
        if (!currentAppointmentDetails ||
        String(currentAppointmentDetails.status).toLowerCase() === "cancelled") return;

        clearEditAppointmentErrors();
        document.getElementById("EditAppointmentUid").value = currentAppointmentDetails.appointmentUid;
        document.getElementById("EditPrimaryResourceUid").value = currentAppointmentDetails.primaryResourceUid || "";
        document.getElementById("EditRoomResourceUid").value = currentAppointmentDetails.roomResourceUid || "";
        document.getElementById("EditStartDateTimeLocal").value =
        localInputValue(new Date(currentAppointmentDetails.startDateTimeLocal));
        document.getElementById("EditEndDateTimeLocal").value =
        localInputValue(new Date(currentAppointmentDetails.endDateTimeLocal));
        document.getElementById("EditAppointmentType").value = currentAppointmentDetails.appointmentType || "";
        document.getElementById("EditReason").value = currentAppointmentDetails.reason || "";
        document.getElementById("EditNotes").value = currentAppointmentDetails.notes || "";

        appointmentDetailsModalElement.addEventListener(
        "hidden.bs.modal",
        () => editAppointmentModal.show(),
        { once: true });
        detailsModal.hide();
        });

        saveEditAppointmentButton.addEventListener("click", async () => {
        clearEditAppointmentErrors();
        saveEditAppointmentButton.disabled = true;

        try {
        const formData = new FormData(editAppointmentForm);
        const editStart = new Date(formData.get("StartDateTimeLocal"));
        const editEnd = new Date(formData.get("EndDateTimeLocal"));
        if (hasBlockedTimeConflict(formData.get("PrimaryResourceUid"), editStart, editEnd) ||
        (formData.get("RoomResourceUid") &&
        hasBlockedTimeConflict(formData.get("RoomResourceUid"), editStart, editEnd))) {
        editAppointmentMessage.textContent = "This resource is blocked during the selected time.";
        editAppointmentMessage.classList.remove("d-none");
        return;
        }
        const token = document.querySelector(
        '#schedulingAntiforgeryForm input[name="__RequestVerificationToken"]').value;
        const response = await fetch(updateAppointmentUrl, {
        method: "POST",
        headers: { "RequestVerificationToken": token },
        body: formData
        });
        const result = await response.json().catch(() => ({}));

        if (!response.ok || !result.success) {
        editAppointmentMessage.textContent =
        result.message || "The appointment could not be updated. Please try again.";
        editAppointmentMessage.classList.remove("d-none");
        showEditAppointmentErrors(result.errors);
        return;
        }

        editAppointmentModal.hide();
        currentAppointmentUid = null;
        currentAppointmentDetails = null;
        await refreshCalendar();
        showSchedulingActionMessage(result.message || "Appointment updated.", "success");
        } catch (error) {
        console.error(error);
        editAppointmentMessage.textContent = "The appointment could not be updated. Please try again.";
        editAppointmentMessage.classList.remove("d-none");
        } finally {
        saveEditAppointmentButton.disabled = false;
        }
        });

        cancelAppointmentButton.addEventListener("click", () => {
        if (!currentAppointmentUid) return;
        cancelAppointmentReason.value = "";
        cancelAppointmentMessage.classList.add("d-none");
        appointmentDetailsModalElement.addEventListener(
        "hidden.bs.modal",
        () => cancelAppointmentModal.show(),
        { once: true });
        detailsModal.hide();
        });

        document.getElementById("keepAppointmentButton").addEventListener("click", () => {
        cancelAppointmentModalElement.addEventListener(
        "hidden.bs.modal",
        () => detailsModal.show(),
        { once: true });
        cancelAppointmentModal.hide();
        });

        confirmCancelAppointmentButton.addEventListener("click", async () => {
        if (!currentAppointmentUid) return;
        confirmCancelAppointmentButton.disabled = true;
        cancelAppointmentMessage.classList.add("d-none");

        try {
        const formData = new FormData();
        formData.append("AppointmentUid", currentAppointmentUid);
        formData.append("CancelReason", cancelAppointmentReason.value);
        const token = document.querySelector(
        '#schedulingAntiforgeryForm input[name="__RequestVerificationToken"]').value;
        const response = await fetch(cancelAppointmentUrl, {
        method: "POST",
        headers: { "RequestVerificationToken": token },
        body: formData
        });
        const result = await response.json().catch(() => ({}));

        if (!response.ok || !result.success) {
        cancelAppointmentMessage.textContent =
        result.message || "Appointment could not be cancelled.";
        cancelAppointmentMessage.classList.remove("d-none");
        return;
        }

        cancelAppointmentModal.hide();
        currentAppointmentUid = null;
        await refreshCalendar();
        showSchedulingActionMessage(
        result.message || "Appointment cancelled.",
        "success");
        } catch (error) {
        console.error(error);
        cancelAppointmentMessage.textContent = "Appointment could not be cancelled.";
        cancelAppointmentMessage.classList.remove("d-none");
        } finally {
        confirmCancelAppointmentButton.disabled = false;
        }
        });

        const localInputValue = date => {
        const pad = value => String(value).padStart(2, "0");
        return `${date.getFullYear()}-${pad(date.getMonth() + 1)}-${pad(date.getDate())}T${pad(date.getHours())}:${pad(date.getMinutes())}`;
        };

        document.getElementById("keepCurrentTimeButton").addEventListener("click", async () => {
        pendingMove = null;
        moveAppointmentModal.hide();
        await refreshCalendar();
        });

        confirmMoveButton.addEventListener("click", async () => {
        if (!pendingMove) return;
        confirmMoveButton.disabled = true;
        moveAppointmentMessage.classList.add("d-none");
        try {
        const formData = new FormData();
        formData.append("AppointmentUid", pendingMove.appointmentUid);
        formData.append("PrimaryResourceUid", pendingMove.primaryResourceUid);
        if (pendingMove.roomResourceUid) formData.append("RoomResourceUid", pendingMove.roomResourceUid);
        formData.append("StartDateTimeLocal", localInputValue(pendingMove.startDateTimeLocal));
        formData.append("EndDateTimeLocal", localInputValue(pendingMove.endDateTimeLocal));
        const token = document.querySelector('#schedulingAntiforgeryForm input[name="__RequestVerificationToken"]').value;
        const response = await fetch("/Scheduling/RescheduleAppointment", {
        method: "POST",
        headers: { "RequestVerificationToken": token },
        body: formData
        });
        const result = await response.json().catch(() => ({}));
        if (!response.ok || !result.success) {
        moveAppointmentMessage.textContent = result.message || "The appointment could not be moved. Please try again.";
        moveAppointmentMessage.classList.remove("d-none");
        await refreshCalendar();
        return;
        }
        pendingMove = null;
        moveAppointmentModal.hide();
        await refreshCalendar();
        } catch (error) {
        console.error(error);
        moveAppointmentMessage.textContent = "The appointment could not be moved. Please try again.";
        moveAppointmentMessage.classList.remove("d-none");
        await refreshCalendar();
        } finally {
        confirmMoveButton.disabled = false;
        }
        });

        moveAppointmentModalElement.addEventListener("hidden.bs.modal", () => {
        if (pendingMove) {
        pendingMove = null;
        refreshCalendar();
        }
        });

        const getVisibleResourceChoices = () => {
        const searchTerm = resourcePickerSearch.value.trim().toLocaleLowerCase();
        return resources.filter(resource =>
        (!selectedResourceType || resource.resourceType === selectedResourceType) &&
        (!searchTerm || resource.displayName.toLocaleLowerCase().includes(searchTerm)));
        };

        const refreshResourcePickerList = () => {
        const matchingResources = getVisibleResourceChoices();
        resourcePickerList.replaceChildren();
        if (!matchingResources.length) {
        const empty = document.createElement("div");
        empty.className = "list-group-item text-body-secondary";
        empty.textContent = "No resources match the current search.";
        resourcePickerList.appendChild(empty);
        return;
        }

        matchingResources.forEach(resource => {
        const label = document.createElement("label");
        label.className = "list-group-item resource-picker-item";
        const left = document.createElement("span");
        left.className = "d-flex align-items-center gap-2";
        const checkbox = document.createElement("input");
        checkbox.type = "checkbox";
        checkbox.className = "form-check-input mt-0";
        checkbox.checked = pendingResourceUids.has(resource.resourceUid);
        checkbox.addEventListener("change", () => {
        if (checkbox.checked) pendingResourceUids.add(resource.resourceUid);
        else pendingResourceUids.delete(resource.resourceUid);
        });
        const name = document.createElement("span");
        name.textContent = resource.displayName;
        const type = document.createElement("span");
        type.className = "badge text-bg-light";
        type.textContent = resource.resourceType;
        left.append(checkbox, name);
        label.append(left, type);
        resourcePickerList.appendChild(label);
        });
        };

        document.getElementById("openResourcePickerButton").addEventListener("click", () => {
        pendingResourceUids = new Set(selectedResourceUids);
        resourcePickerSearch.value = "";
        refreshResourcePickerList();
        resourcePickerModal.show();
        });
        resourcePickerSearch.addEventListener("input", refreshResourcePickerList);
        document.getElementById("selectAllVisibleResourcesButton").addEventListener("click", () => {
        getVisibleResourceChoices().forEach(resource =>
        pendingResourceUids.add(resource.resourceUid));
        refreshResourcePickerList();
        });
        document.getElementById("applyResourceSelectionButton").addEventListener("click", async () => {
        selectedResourceUids = new Set(pendingResourceUids);
        resourcePickerModal.hide();
        await refreshCalendar();
        });
        document.getElementById("clearResourceSelectionButton").addEventListener("click", async () => {
        selectedResourceUids.clear();
        pendingResourceUids.clear();
        resourcePickerSearch.value = "";
        resourcePickerModal.hide();
        await refreshCalendar();
        });

        const openAppointmentModal = (start, resourceUid) => {
        appointmentForm.reset();
        clearAppointmentErrors();
        document.getElementById("PatientUid").value = "";
        selectedPatientLabel.textContent = "No patient selected.";
        hidePatientSearchResults();
        const startDate = start.toDateLocal();
        const endDate = new Date(startDate.getTime() + 15 * 60000);
        document.getElementById("StartDateTimeLocal").value = localInputValue(startDate);
        document.getElementById("EndDateTimeLocal").value = localInputValue(endDate);
        const clickedResource = resources.find(resource => resource.resourceUid === resourceUid);
        const firstVisibleProvider = getFilteredResources().find(resource => resource.resourceType === "Provider");
        const firstProvider = resources.find(resource => resource.resourceType === "Provider");
        document.getElementById("PrimaryResourceUid").value =
        clickedResource?.resourceType === "Provider"
        ? resourceUid
        : firstVisibleProvider?.resourceUid || firstProvider?.resourceUid || "";
        if (clickedResource?.resourceType === "Room") {
        document.getElementById("RoomResourceUid").value = resourceUid;
        }
        appointmentModal.show();
        };

        const openAppointmentModalForDefaultSlot = () => {
        const selectedLocalDate = selectedDate.toDateLocal();
        const now = new Date();
        const isToday =
        selectedLocalDate.getFullYear() === now.getFullYear() &&
        selectedLocalDate.getMonth() === now.getMonth() &&
        selectedLocalDate.getDate() === now.getDate();
        const start = new Date(selectedLocalDate);

        if (isToday) {
        start.setHours(now.getHours(), now.getMinutes(), 0, 0);
        const remainder = start.getMinutes() % 15;
        if (remainder !== 0) start.setMinutes(start.getMinutes() + 15 - remainder);
        } else {
        start.setHours(8, 0, 0, 0);
        }

        const firstVisibleProvider = getFilteredResources()
        .find(resource => resource.resourceType === "Provider");
        const firstProvider = resources
        .find(resource => resource.resourceType === "Provider");
        openAppointmentModal(
        new DayPilot.Date(localInputValue(start)),
        firstVisibleProvider?.resourceUid || firstProvider?.resourceUid);
        };

        const clearAppointmentErrors = () => {
        appointmentMessage.className = "alert d-none";
        appointmentMessage.textContent = "";
        appointmentForm.querySelectorAll(".is-invalid").forEach(element => element.classList.remove("is-invalid"));
        appointmentForm.querySelectorAll("[data-error-for]").forEach(element => element.textContent = "");
        };

        const showMessage = (message, style = "danger") => {
        appointmentMessage.className = `alert alert-${style}`;
        appointmentMessage.textContent = message;
        };

        const searchPatients = async () => {
        const term = document.getElementById("patientSearchTerm").value.trim();
        searchResults.replaceChildren();
        if (term.length < 2) {
        showMessage("Enter at least two characters to search for a patient.");
        hidePatientSearchResults();
        return;
        }
        clearAppointmentErrors();
        const response = await fetch(`/Scheduling/SearchPatients?term=${encodeURIComponent(term)}`);
        if (!response.ok) {
        showMessage("Patient search is unavailable. Please try again.");
        hidePatientSearchResults();
        return;
        }
        const patients = await response.json();
        if (!patients.length) {
        const empty = document.createElement("div");
        empty.className = "patient-search-empty";
        empty.textContent = "No patients found.";
        searchResults.appendChild(empty);
        showPatientSearchResults();
        return;
        }
        patients.forEach(patient => {
        const button = document.createElement("button");
        button.type = "button";
        button.className = "patient-search-item";
        button.textContent = `${patient.displayName} — ${patient.chartNumber}${patient.dateOfBirth ? ` — DOB ${patient.dateOfBirth}` : ""}`;
        button.addEventListener("click", () => {
        document.getElementById("PatientUid").value = patient.patientUid;
        selectedPatientLabel.textContent = `${patient.displayName} (${patient.chartNumber})`;
        document.getElementById("patientSearchTerm").value = patient.displayName;
        hidePatientSearchResults();
        });
        searchResults.appendChild(button);
        });
        showPatientSearchResults();
        };

        document.getElementById("patientSearchButton").addEventListener("click", searchPatients);
        document.getElementById("patientSearchTerm").addEventListener("keydown", event => {
        if (event.key === "Enter") { event.preventDefault(); searchPatients(); }
        });
        document.addEventListener("click", event => {
        const container = document.querySelector(".patient-search-container");
        if (container && !container.contains(event.target)) hidePatientSearchResults();
        });
        document.getElementById("addAppointmentModal").addEventListener("hidden.bs.modal", () => {
        hidePatientSearchResults();
        });

        document.getElementById("saveAppointmentButton").addEventListener("click", async event => {
        clearAppointmentErrors();
        const button = event.currentTarget;
        button.disabled = true;
        try {
        const formData = new FormData(appointmentForm);
        const appointmentStart = new Date(formData.get("StartDateTimeLocal"));
        const appointmentEnd = new Date(formData.get("EndDateTimeLocal"));
        if (hasBlockedTimeConflict(formData.get("PrimaryResourceUid"), appointmentStart, appointmentEnd) ||
        (formData.get("RoomResourceUid") &&
        hasBlockedTimeConflict(formData.get("RoomResourceUid"), appointmentStart, appointmentEnd))) {
        showMessage("This resource is blocked during the selected time.");
        return;
        }
        const token = document.querySelector('#schedulingAntiforgeryForm input[name="__RequestVerificationToken"]').value;
        const response = await fetch("/Scheduling/CreateAppointment", {
        method: "POST",
        headers: { "RequestVerificationToken": token },
        body: formData
        });
        const result = await response.json();
        if (!response.ok || !result.success) {
        showMessage(result.message || "The appointment could not be saved.");
        Object.entries(result.errors || {}).forEach(([name, messages]) => {
        const input = document.getElementById(name);
        if (input) input.classList.add("is-invalid");
        const feedback = appointmentForm.querySelector(`[data-error-for="${name}"]`);
        if (feedback) feedback.textContent = messages.join(" ");
        });
        return;
        }
        appointmentModal.hide();
        appointmentForm.reset();
        await refreshCalendar();
        } catch (error) {
        console.error(error);
        showMessage("The appointment could not be saved. Please try again.");
        } finally {
        button.disabled = false;
        }
        });

        const setDateLabel = () => {
        dateLabel.textContent =
        selectedDate.toDateLocal().toLocaleDateString(
        undefined,
        {
        weekday: "long",
        month: "short",
        day: "numeric",
        year: "numeric"
        });
        };

        const dayRange = () => {
        const start = selectedDate.toDateLocal();
        start.setHours(0, 0, 0, 0);

        const end = new Date(start);
        end.setDate(end.getDate() + 1);

        return {
        start: start.toISOString(),
        end: end.toISOString()
        };
        };

        const loadEvents = async () => {
        const range = dayRange();
        const url = new URL(
        "/Scheduling/Events",
        window.location.origin);

        url.searchParams.set("start", range.start);
        url.searchParams.set("end", range.end);

        const response = await fetch(url);

        if (!response.ok) {
        throw new Error(
        `Scheduling events request failed: ${response.status}`);
        }

        const events = await response.json();
        const blockedUrl = new URL("/Scheduling/BlockedTimes", window.location.origin);
        blockedUrl.searchParams.set("startDateTimeUtc", range.start);
        blockedUrl.searchParams.set("endDateTimeUtc", range.end);
        const blockedResponse = await fetch(blockedUrl, {
        headers: { "Accept": "application/json" }
        });
        const blockedResult = await blockedResponse.json().catch(() => ({}));
        if (!blockedResponse.ok || !blockedResult.success) {
        throw new Error(blockedResult.message || "Blocked times could not be loaded.");
        }
        blockedTimes = blockedResult.blockedTimes || [];
        const blockedEvents = blockedTimes.map(block => ({
        id: `blocked-${block.blockedTimeUid}`,
        text: `Blocked${block.reason ? `: ${block.reason}` : ""}`,
        start: block.startDateTimeUtc,
        end: block.endDateTimeUtc,
        resource: block.resourceUid,
        eventKind: "blockedTime",
        blockedTimeUid: block.blockedTimeUid,
        reason: block.reason,
        moveDisabled: true,
        resizeDisabled: true,
        backColor: "#6c757d",
        borderColor: "#495057",
        fontColor: "#ffffff"
        }));
        const visibleResourceUids = new Set(getFilteredResources().map(resource => resource.resourceUid));
        return [...events.map(event => ({ ...event, eventKind: "appointment" })), ...blockedEvents]
        .filter(event => visibleResourceUids.has(event.resource));
        };

        const refreshCalendar = async () => {
        setDateLabel();
        updateResourceFilterSummary();

        calendar.update({
        startDate: selectedDate,
        columns: toColumns(),
        events: []
        });

        try {
        const events = await loadEvents();

        calendar.update({
        events
        });
        } catch (error) {
        console.error(error);
        calendar.update({
        events: []
        });
        }
        };

        const dateKey = date => {
        const pad = value => String(value).padStart(2, "0");
        return `${date.getFullYear()}-${pad(date.getMonth() + 1)}-${pad(date.getDate())}`;
        };

        const refreshMonthView = async () => {
        const year = selectedMonthDate.getFullYear();
        const month = selectedMonthDate.getMonth();
        const monthStart = new Date(year, month, 1);
        const monthEnd = new Date(year, month + 1, 1);
        monthLabel.textContent = monthStart.toLocaleDateString(undefined, { month: "long", year: "numeric" });
        monthMessage.classList.add("d-none");
        monthGrid.replaceChildren();

        ["Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat"].forEach(dayName => {
        const header = document.createElement("div");
        header.className = "scheduling-month-header";
        header.textContent = dayName;
        monthGrid.appendChild(header);
        });

        for (let index = 0; index < monthStart.getDay(); index++) {
        const blank = document.createElement("div");
        blank.className = "scheduling-month-blank";
        blank.setAttribute("aria-hidden", "true");
        monthGrid.appendChild(blank);
        }

        let summaryByDate = new Map();
        try {
        const url = new URL("/Scheduling/MonthSummary", window.location.origin);
        url.searchParams.set("start", monthStart.toISOString());
        url.searchParams.set("end", monthEnd.toISOString());
        const response = await fetch(url);
        if (!response.ok) throw new Error(`Month summary request failed: ${response.status}`);
        const summary = await response.json();
        summaryByDate = new Map(summary.map(item => [String(item.date).slice(0, 10), item]));
        } catch (error) {
        console.error(error);
        monthMessage.textContent = "The month appointment summary could not be loaded. Please try again.";
        monthMessage.classList.remove("d-none");
        }

        const todayKey = dateKey(new Date());
        const selectedKey = selectedDate.toString("yyyy-MM-dd");
        const daysInMonth = new Date(year, month + 1, 0).getDate();
        for (let day = 1; day <= daysInMonth; day++) {
        const date = new Date(year, month, day);
        const key = dateKey(date);
        const item = summaryByDate.get(key);
        const count = item?.appointmentCount || 0;
        const status = item?.status || "No appointments";
        const cell = document.createElement("button");
        cell.type = "button";
        cell.className = "scheduling-month-day";
        if (key === todayKey) cell.classList.add("is-today");
        if (key === selectedKey) cell.classList.add("is-selected");
        cell.innerHTML = `<div class="scheduling-month-day-number">${day}</div>` +
        `<div class="scheduling-month-day-summary">${count} ${count === 1 ? "appointment" : "appointments"}<br>${status}</div>`;
        cell.addEventListener("click", async () => {
        selectedDate = new DayPilot.Date(key);
        selectedMonthDate = date;
        await showDayView();
        });
        monthGrid.appendChild(cell);
        }
        };

        const showDayView = async () => {
        currentView = "day";
        monthView.classList.add("d-none");
        dayView.classList.remove("d-none");
        dayViewButton.className = "btn btn-primary";
        dayViewButton.setAttribute("aria-pressed", "true");
        monthViewButton.className = "btn btn-outline-secondary";
        monthViewButton.setAttribute("aria-pressed", "false");
        viewTitle.textContent = "Day View";
        await refreshCalendar();
        };

        const showMonthView = async () => {
        currentView = "month";
        selectedMonthDate = selectedDate.toDateLocal();
        selectedMonthDate.setDate(1);
        dayView.classList.add("d-none");
        monthView.classList.remove("d-none");
        monthViewButton.className = "btn btn-primary";
        monthViewButton.setAttribute("aria-pressed", "true");
        dayViewButton.className = "btn btn-outline-secondary";
        dayViewButton.setAttribute("aria-pressed", "false");
        viewTitle.textContent = "Month View";
        await refreshMonthView();
        };

        document
        .getElementById("schedulingPreviousButton")
        .addEventListener("click", async () => {
        selectedDate = selectedDate.addDays(-1);
        await refreshCalendar();
        });

        document
        .getElementById("schedulingTodayButton")
        .addEventListener("click", async () => {
        selectedDate = DayPilot.Date.today();
        await refreshCalendar();
        });

        document
        .getElementById("schedulingNextButton")
        .addEventListener("click", async () => {
        selectedDate = selectedDate.addDays(1);
        await refreshCalendar();
        });

        resourceTypeFilter.addEventListener("change", async () => {
        selectedResourceType = resourceTypeFilter.value;
        refreshResourcePickerList();
        await refreshCalendar();
        });

        monthViewButton.addEventListener("click", showMonthView);
        dayViewButton.addEventListener("click", showDayView);
        document.getElementById("schedulingPreviousMonthButton").addEventListener("click", async () => {
        selectedMonthDate = new Date(selectedMonthDate.getFullYear(), selectedMonthDate.getMonth() - 1, 1);
        await refreshMonthView();
        });
        document.getElementById("schedulingMonthTodayButton").addEventListener("click", async () => {
        selectedMonthDate = new Date();
        selectedMonthDate.setDate(1);
        await refreshMonthView();
        });
        document.getElementById("schedulingNextMonthButton").addEventListener("click", async () => {
        selectedMonthDate = new Date(selectedMonthDate.getFullYear(), selectedMonthDate.getMonth() + 1, 1);
        await refreshMonthView();
        });

        await refreshCalendar();
        if (shouldOpenAddAppointment) {
        openAppointmentModalForDefaultSlot();
        }
        });
    </script>
}
