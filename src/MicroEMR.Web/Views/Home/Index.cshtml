@using System.Security.Claims

@model MicroEMR.Web.Models.Dashboard.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
    ViewData["Subtitle"] = "Overview of today's clinic activity";
    Layout = "_AppLayout";

    var displayName =
        User.FindFirst("given_name")?.Value
        ?? User.FindFirst("name")?.Value
        ?? User.Identity?.Name
        ?? "User";

    var appointmentStatuses = new[]
    {
        "Scheduled", "Arrived", "Roomed", "Seen", "Completed"
    };
}

<form id="dashboardAntiforgeryForm" class="d-none">
    @Html.AntiForgeryToken()
</form>

<div class="container-fluid p-0">

    <section class="dashboard-welcome mb-4">
        <div>
            <h2 class="dashboard-welcome-title">
                Welcome back, @displayName
            </h2>

            <p class="dashboard-welcome-text">
                Here is an overview of today's clinic activity.
            </p>
        </div>

        <div class="dashboard-date">
            <i class="bi bi-calendar3 me-2"></i>
            @DateTime.Now.ToString("dddd, MMMM d, yyyy")
        </div>
    </section>

    <div class="row g-4">

        <div class="col-12 col-sm-6 col-xl-3">
            <div class="dashboard-card">
                <div class="dashboard-card-icon icon-blue">
                    <i class="bi bi-calendar-check"></i>
                </div>

                <div>
                    <div class="dashboard-card-value">@Model.TodaysAppointmentCount</div>
                    <div class="dashboard-card-label">
                        Today's Appointments
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-xl-3">
            <div class="dashboard-card">
                <div class="dashboard-card-icon icon-green">
                    <i class="bi bi-person-check"></i>
                </div>

                <div>
                    <div class="dashboard-card-value">0</div>
                    <div class="dashboard-card-label">
                        Patients Checked In
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-xl-3">
            <div class="dashboard-card">
                <div class="dashboard-card-icon icon-orange">
                    <i class="bi bi-clock-history"></i>
                </div>

                <div>
                    <div class="dashboard-card-value">0</div>
                    <div class="dashboard-card-label">
                        Waiting
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-xl-3">
            <div class="dashboard-card">
                <div class="dashboard-card-icon icon-purple">
                    <i class="bi bi-file-earmark-medical"></i>
                </div>

                <div>
                    <div class="dashboard-card-value">0</div>
                    <div class="dashboard-card-label">
                        Documents to Review
                    </div>
                </div>
            </div>
        </div>

    </div>

    <div class="row g-4 mt-1">

        <div class="col-12 col-xl-8">
            <section class="content-panel">
                <div class="content-panel-header">
                    <div>
                        <h3>Today's Schedule</h3>
                        <p>Upcoming appointments and clinic resources</p>
                    </div>

                    <a asp-controller="Scheduling"
                       asp-action="Index"
                       asp-route-date="@DateTime.Today.ToString("yyyy-MM-dd")"
                       class="btn btn-outline-primary btn-sm">
                        View schedule
                    </a>
                </div>

                <div id="dashboardScheduleMessage" class="alert d-none mt-3 mb-0" role="alert"></div>

                @if (Model.ScheduleLoadFailed)
                {
                    <div class="alert alert-warning mt-3 mb-0" role="alert">
                        Today's schedule could not be loaded.
                    </div>
                }
                else if (Model.TodaysAppointments.Count > 0)
                {
                    <div class="table-responsive mt-3">
                        <table class="table table-hover align-middle mb-0">
                            <thead>
                                <tr>
                                    <th scope="col">Time</th>
                                    <th scope="col">Patient</th>
                                    <th scope="col">Provider</th>
                                    <th scope="col">Type / Reason</th>
                                    <th scope="col">Status</th>
                                    <th scope="col" class="text-end">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var appointment in Model.TodaysAppointments)
                                {
                                    <tr>
                                        <td class="text-nowrap">@appointment.StartDateTimeLocal.ToString("h:mm tt")</td>
                                        <td>
                                            <div class="fw-semibold">@appointment.PatientDisplayName</div>
                                            <div class="small text-body-secondary">
                                                @(appointment.ChartNumber ?? "No chart number")
                                            </div>
                                        </td>
                                        <td>@(appointment.PrimaryResourceName ?? "Not assigned")</td>
                                        <td>
                                            @(appointment.AppointmentType
                                                ?? appointment.Reason
                                                ?? "Not specified")
                                        </td>
                                        <td>
                                            <select class="form-select form-select-sm appointment-status-select"
                                                    data-appointment-uid="@appointment.AppointmentUid"
                                                    aria-label="Appointment status for @appointment.PatientDisplayName">
                                                @foreach (var status in appointmentStatuses)
                                                {
                                                    <option value="@status" selected="@(status == appointment.Status)">@status</option>
                                                }
                                            </select>
                                        </td>
                                        <td class="text-end text-nowrap">
                                            <a asp-controller="Patients"
                                               asp-action="Details"
                                               asp-route-patientUid="@appointment.PatientUid"
                                               class="btn btn-sm btn-outline-primary">Open Chart</a>
                                            <a asp-controller="Scheduling"
                                               asp-action="Index"
                                               asp-route-date="@appointment.StartDateTimeLocal.ToString("yyyy-MM-dd")"
                                               class="btn btn-sm btn-outline-secondary">Schedule</a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    @if (Model.TodaysAppointmentCount > Model.TodaysAppointments.Count)
                    {
                        <div class="mt-3 text-end">
                            <a asp-controller="Scheduling"
                               asp-action="Index"
                               asp-route-date="@DateTime.Today.ToString("yyyy-MM-dd")">
                                View full schedule
                            </a>
                        </div>
                    }
                }
                else
                {
                    <div class="empty-state">
                        <div class="empty-state-icon"><i class="bi bi-calendar2-week"></i></div>
                        <h4>No appointments scheduled for today.</h4>
                        <a asp-controller="Scheduling"
                           asp-action="Index"
                           asp-route-openAddAppointment="true"
                           class="btn btn-primary btn-sm mt-2">Book Appointment</a>
                    </div>
                }
            </section>
        </div>

        <div class="col-12 col-xl-4">
            <section class="content-panel">
                <div class="content-panel-header">
                    <div>
                        <h3>Quick Actions</h3>
                        <p>Common application tasks</p>
                    </div>
                </div>

                <div class="quick-action-list">
                    <a asp-controller="Scheduling"
                       asp-action="Index"
                       asp-route-openAddAppointment="true"
                       class="quick-action">

                        <span class="quick-action-icon">
                            <i class="bi bi-calendar-plus"></i>
                        </span>

                        <span>
                            <strong>Book appointment</strong>
                            <small>Create a new appointment</small>
                        </span>
                    </a>

                    <a asp-controller="Patients"
                       asp-action="Search"
                       class="quick-action">

                        <span class="quick-action-icon">
                            <i class="bi bi-search"></i>
                        </span>

                        <span>
                            <strong>Find patient</strong>
                            <small>Search patient records</small>
                        </span>
                    </a>

                    <a asp-controller="Patients"
                       asp-action="Create"
                       class="quick-action">

                        <span class="quick-action-icon">
                            <i class="bi bi-person-plus"></i>
                        </span>

                        <span>
                            <strong>Register patient</strong>
                            <small>Add a new patient</small>
                        </span>
                    </a>
                </div>
            </section>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        (() => {
            const updateStatusUrl = '@Url.Action("UpdateAppointmentStatus", "Home")';
            const tokenInput = document.querySelector(
                '#dashboardAntiforgeryForm input[name="__RequestVerificationToken"]');
            const messageElement = document.getElementById('dashboardScheduleMessage');

            const showMessage = (message, type) => {
                if (!messageElement) return;
                messageElement.className = `alert alert-${type} mt-3 mb-0`;
                messageElement.textContent = message;
            };

            document.querySelectorAll('.appointment-status-select').forEach(dropdown => {
                dropdown.dataset.previousStatus = dropdown.value;

                dropdown.addEventListener('change', async () => {
                    const previousStatus = dropdown.dataset.previousStatus;
                    dropdown.disabled = true;

                    try {
                        const formData = new FormData();
                        formData.append('AppointmentUid', dropdown.dataset.appointmentUid);
                        formData.append('Status', dropdown.value);

                        const response = await fetch(updateStatusUrl, {
                            method: 'POST',
                            headers: {
                                'RequestVerificationToken': tokenInput?.value ?? ''
                            },
                            body: formData
                        });
                        const result = await response.json();

                        if (!response.ok || !result.success) {
                            dropdown.value = previousStatus;
                            showMessage(
                                result.message || 'Appointment status could not be updated.',
                                'danger');
                            return;
                        }

                        dropdown.value = result.status;
                        dropdown.dataset.previousStatus = result.status;
                        showMessage(result.message || 'Appointment status updated.', 'success');
                    } catch (error) {
                        console.error('Appointment status update failed.', error);
                        dropdown.value = previousStatus;
                        showMessage('Appointment status could not be updated.', 'danger');
                    } finally {
                        dropdown.disabled = false;
                    }
                });
            });
        })();
    </script>
}
