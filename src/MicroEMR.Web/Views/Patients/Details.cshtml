@model MicroEMR.Web.Models.Patients.PatientChartViewModel

@{
    var patient = Model.Patient;

    ViewData ["Title"] = "Patient Chart";
    ViewData ["Subtitle"] = patient.ChartNumber;
    Layout = "_AppLayout";

    var demographicsActive =
        Model.ActiveTab == "demographics";

    var documentsActive =
        Model.ActiveTab == "documents";

    var encountersActive =
        Model.ActiveTab == "encounters";

    var allergiesActive =
        Model.ActiveTab == "allergies";

    var medicationsActive =
        Model.ActiveTab == "medications";
}

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">

        <i class="bi bi-check-circle me-2"></i>
        @successMessage

        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close">
        </button>
    </div>
}

@if (TempData["WarningMessage"] is string warningMessage)
{
    <div class="alert alert-warning alert-dismissible fade show" role="alert">

        <i class="bi bi-exclamation-triangle me-2"></i>
        @warningMessage

        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close">
        </button>
    </div>
}

<ul class="nav nav-tabs mb-3">
    <li class="nav-item">
        <button class="nav-link @(demographicsActive ? "active" : null)"
                data-bs-toggle="tab"
                data-bs-target="#demographics"
                type="button">
            Demographics
        </button>
    </li>

    <li class="nav-item">
        <button class="nav-link @(documentsActive ? "active" : null)"
                data-bs-toggle="tab"
                data-bs-target="#documents"
                type="button">
            Documents
        </button>
    </li>

    <li class="nav-item">
        <button class="nav-link @(encountersActive ? "active" : null)"
                data-bs-toggle="tab"
                data-bs-target="#encounters"
                type="button">
            Encounters
        </button>
    </li>

    <li class="nav-item">
        <button class="nav-link @(allergiesActive ? "active" : null)"
                data-bs-toggle="tab"
                data-bs-target="#allergies"
                type="button">
            Allergies
        </button>
    </li>

    <li class="nav-item">
        <button class="nav-link @(medicationsActive ? "active" : null)"
                data-bs-toggle="tab"
                data-bs-target="#medications"
                type="button">
            Medications
        </button>
    </li>
</ul>

<div class="tab-content">
    <div class="tab-pane fade @(demographicsActive ? "show active" : null)"
         id="demographics"
         role="tabpanel">

        <div class="content-panel">

            <div class="content-panel-header">
                <div>
                    <h3>@patient.FullName</h3>

                    <p>
                        Chart number:
                        <strong>@patient.ChartNumber</strong>
                    </p>
                </div>

                <div class="d-flex gap-2">
                    <a asp-action="Search" class="btn btn-outline-secondary">

                        <i class="bi bi-arrow-left me-1"></i>
                        Back
                    </a>

                    <a asp-controller="Patients"
                       asp-action="Edit"
                       asp-route-patientUid="@patient.PatientUid"
                       class="btn btn-outline-primary">
                        <i class="bi bi-pencil me-1"></i>
                        Edit
                    </a>
                </div>
            </div>

            <div class="row g-4 mt-1">

                <div class="col-12 col-lg-6">
                    <div class="border rounded-3 p-3 h-100">
                        <h5 class="mb-3">Demographics</h5>

                        <dl class="row mb-0">
                            <dt class="col-sm-5">Legal name</dt>
                            <dd class="col-sm-7">@patient.FullName</dd>

                            <dt class="col-sm-5">Preferred name</dt>
                            <dd class="col-sm-7">
                                @(patient.PreferredName ?? "—")
                            </dd>

                            <dt class="col-sm-5">Date of birth</dt>
                            <dd class="col-sm-7">
                                @patient.DateOfBirth.ToString("MMMM d, yyyy")
                            </dd>

                            <dt class="col-sm-5">Sex at birth</dt>
                            <dd class="col-sm-7">
                                @(patient.SexAtBirth ?? "—")
                            </dd>

                            <dt class="col-sm-5">Gender identity</dt>
                            <dd class="col-sm-7">
                                @(patient.GenderIdentity ?? "—")
                            </dd>
                        </dl>
                    </div>
                </div>

                <div class="col-12 col-lg-6">
                    <div class="border rounded-3 p-3 h-100">
                        <h5 class="mb-3">Health card</h5>

                        <dl class="row mb-0">
                            <dt class="col-sm-5">Number</dt>
                            <dd class="col-sm-7">
                                @(patient.HealthCardNumber ?? "—")
                            </dd>

                            <dt class="col-sm-5">Version</dt>
                            <dd class="col-sm-7">
                                @(patient.HealthCardVersion ?? "—")
                            </dd>

                            <dt class="col-sm-5">Status</dt>
                            <dd class="col-sm-7">
                                @if (patient.IsActive)
                                {
                                    <span class="badge text-bg-success">
                                        Active
                                    </span>
                                }
                                else
                                {
                                    <span class="badge text-bg-secondary">
                                        Inactive
                                    </span>
                                }
                            </dd>
                        </dl>
                    </div>
                </div>

                <div class="col-12 col-lg-6">
                    <div class="border rounded-3 p-3 h-100">
                        <h5 class="mb-3">Contact</h5>

                        <dl class="row mb-0">
                            <dt class="col-sm-5">Phone</dt>
                            <dd class="col-sm-7">
                                @(patient.PhoneNumber ?? "—")
                            </dd>

                            <dt class="col-sm-5">Alternate phone</dt>
                            <dd class="col-sm-7">
                                @(patient.AlternatePhoneNumber ?? "—")
                            </dd>

                            <dt class="col-sm-5">Email</dt>
                            <dd class="col-sm-7">
                                @(patient.Email ?? "—")
                            </dd>
                        </dl>
                    </div>
                </div>

                <div class="col-12 col-lg-6">
                    <div class="border rounded-3 p-3 h-100">
                        <h5 class="mb-3">Address</h5>

                        <address class="mb-0">
                            @if (!string.IsNullOrWhiteSpace(patient.AddressLine1))
                            {
                                <div>@patient.AddressLine1</div>
                            }

                            @if (!string.IsNullOrWhiteSpace(patient.AddressLine2))
                            {
                                <div>@patient.AddressLine2</div>
                            }

                            <div>
                                @string.Join(
                                    ", ",
                                    new[]
                                    {
                                patient.City,
                                patient.Province
                                    }
                                    .Where(x =>
                                        !string.IsNullOrWhiteSpace(x)))
                            </div>

                            <div>@patient.PostalCode</div>
                            <div>@patient.CountryCode</div>
                        </address>
                    </div>
                </div>

            </div>
        </div>

    </div>

    <div class="tab-pane fade @(documentsActive ? "show active" : null)"
         id="documents"
         role="tabpanel">

        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="mb-0">Patient Documents</h5>

            <a asp-controller="PatientDocuments"
                   asp-action="Create"
                   asp-route-patientUid="@patient.PatientUid"
                   class="btn btn-primary">
                <i class="bi bi-file-earmark-plus me-1"></i>
                New Document
            </a>
        </div>

        @if (Model.Documents.Count == 0)
        {
            <div class="alert alert-light border">
                <i class="bi bi-file-earmark-text me-2"></i>
                No documents have been created for this patient.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Title</th>
                            <th>Type</th>
                            <th>Status</th>
                            <th>Created</th>
                            <th>Created by</th>
                            <th class="text-end">Action</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var document in Model.Documents)
                        {
                            <tr>
                                <td>
                                    <strong>@document.Title</strong>
                                </td>

                                <td>@document.DocumentType</td>

                                <td>
                                    @if (string.Equals(
                                        document.Status,
                                        "Draft",
                                        StringComparison.OrdinalIgnoreCase))
                                    {
                                        <span class="badge text-bg-warning">
                                            Draft
                                        </span>
                                    }
                                    else if (string.Equals(
                                        document.Status,
                                        "Signed",
                                        StringComparison.OrdinalIgnoreCase))
                                    {
                                        <span class="badge text-bg-success">
                                            Signed
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge text-bg-secondary">
                                            @document.Status
                                        </span>
                                    }
                                </td>

                                <td>
                                    @document.CreatedAt.ToLocalTime().ToString("MMM d, yyyy h:mm tt")
                                </td>

                                <td>
                                    @(document.CreatedByDisplayName
                                        ?? "Unknown")
                                </td>

                                <td class="text-end">
                                    <a asp-controller="PatientDocuments"
                                           asp-action="Details"
                                           asp-route-documentUid="@document.DocumentUid"
                                           class="btn btn-sm btn-outline-primary">
                                        Open
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

    <div class="tab-pane fade @(encountersActive ? "show active" : null)"
         id="encounters"
         role="tabpanel">

        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="mb-0">Patient Encounters</h5>

            <a asp-controller="PatientEncounters"
               asp-action="Create"
               asp-route-patientUid="@patient.PatientUid"
               class="btn btn-primary">
                <i class="bi bi-plus-circle me-1"></i>
                New Encounter
            </a>
        </div>

        @if (Model.Encounters.Count == 0)
        {
            <div class="alert alert-light border">
                <i class="bi bi-journal-medical me-2"></i>
                No encounters have been created for this patient.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Type</th>
                            <th>Reason</th>
                            <th>Provider</th>
                            <th>Location</th>
                            <th>Status</th>
                            <th class="text-end">Action</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var encounter in Model.Encounters)
                        {
                            <tr>
                                <td>
                                    @encounter.EncounterDateUtc.ToLocalTime().ToString("MMM d, yyyy h:mm tt")
                                </td>

                                <td>@encounter.EncounterType</td>

                                <td>
                                    @(encounter.ReasonForVisit ?? "—")
                                </td>

                                <td>
                                    @(encounter.ProviderName ?? "—")
                                </td>

                                <td>
                                    @(encounter.LocationName ?? "—")
                                </td>

                                <td>
                                    @if (string.Equals(
                                        encounter.Status,
                                        "Open",
                                        StringComparison.OrdinalIgnoreCase))
                                    {
                                        <span class="badge text-bg-primary">
                                            Open
                                        </span>
                                    }
                                    else if (string.Equals(
                                        encounter.Status,
                                        "Closed",
                                        StringComparison.OrdinalIgnoreCase))
                                    {
                                        <span class="badge text-bg-secondary">
                                            Closed
                                        </span>
                                    }
                                    else if (string.Equals(
                                        encounter.Status,
                                        "Cancelled",
                                        StringComparison.OrdinalIgnoreCase))
                                    {
                                        <span class="badge text-bg-danger">
                                            Cancelled
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge text-bg-secondary">
                                            @encounter.Status
                                        </span>
                                    }
                                </td>

                                <td class="text-end">
                                    <button type="button"
                                            class="btn btn-sm btn-outline-secondary open-encounter-button"
                                            data-patient-uid="@encounter.PatientUid"
                                            data-encounter-uid="@encounter.EncounterUid">
                                        View
                                    </button>
                                    <a asp-controller="PatientEncounters"
                                       asp-action="Details"
                                       asp-route-encounterUid="@encounter.EncounterUid"
                                       class="btn btn-sm btn-outline-primary">
                                        Open
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

    <div class="tab-pane fade @(allergiesActive ? "show active" : null)"
         id="allergies"
         role="tabpanel">

        <div class="d-flex justify-content-between align-items-center gap-3 mb-3">
            <h5 class="mb-0">Patient Allergies</h5>
            <div class="d-flex align-items-center gap-2">
                <label for="allergyStatusFilter" class="form-label mb-0">Show</label>
                <select id="allergyStatusFilter" class="form-select form-select-sm" aria-label="Filter allergies by status">
                    <option value="Active" selected>Active</option>
                    <option value="Resolved">Resolved</option>
                    <option value="All">All</option>
                </select>
                <a asp-controller="PatientAllergies"
                   asp-action="Create"
                   asp-route-patientUid="@patient.PatientUid"
                   class="btn btn-primary text-nowrap">
                    <i class="bi bi-plus-circle me-1"></i>
                    Add Allergy
                </a>
            </div>
        </div>

        <div id="allergyEmptyState" class="alert alert-light border d-none">
            <i class="bi bi-exclamation-triangle me-2"></i>
            <span>No active allergies recorded.</span>
        </div>

        @if (Model.Allergies.Count > 0)
        {
            <div id="allergyTableContainer" class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Allergen</th>
                            <th>Type</th>
                            <th>Reaction</th>
                            <th>Severity</th>
                            <th>Onset</th>
                            <th>Status</th>
                            <th class="text-end">Action</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var allergy in Model.Allergies)
                        {
                            <tr data-allergy-status="@allergy.Status">
                                <td>
                                    <strong>@allergy.AllergenName</strong>
                                </td>

                                <td>
                                    @(allergy.AllergenType ?? "—")
                                </td>

                                <td>
                                    @(allergy.Reaction ?? "—")
                                </td>

                                <td>
                                    @if (string.Equals(
                                        allergy.Severity,
                                        "Severe",
                                        StringComparison.OrdinalIgnoreCase))
                                    {
                                        <span class="badge text-bg-danger">
                                            Severe
                                        </span>
                                    }
                                    else if (string.Equals(
                                        allergy.Severity,
                                        "Moderate",
                                        StringComparison.OrdinalIgnoreCase))
                                    {
                                        <span class="badge text-bg-warning">
                                            Moderate
                                        </span>
                                    }
                                    else if (string.Equals(
                                        allergy.Severity,
                                        "Mild",
                                        StringComparison.OrdinalIgnoreCase))
                                    {
                                        <span class="badge text-bg-info">
                                            Mild
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge text-bg-secondary">
                                            @(allergy.Severity ?? "Unknown")
                                        </span>
                                    }
                                </td>

                                <td>
                                    @(allergy.OnsetDate.HasValue
                                        ? allergy.OnsetDate.Value.ToString("MMM d, yyyy")
                                        : "—")
                                </td>

                                <td>
                                    @if (string.Equals(
                                        allergy.Status,
                                        "Active",
                                        StringComparison.OrdinalIgnoreCase))
                                    {
                                        <span class="badge text-bg-success">
                                            Active
                                        </span>
                                    }
                                    else if (string.Equals(
                                        allergy.Status,
                                        "Inactive",
                                        StringComparison.OrdinalIgnoreCase))
                                    {
                                        <span class="badge text-bg-secondary">
                                            Inactive
                                        </span>
                                    }
                                    else if (string.Equals(
                                        allergy.Status,
                                        "EnteredInError",
                                        StringComparison.OrdinalIgnoreCase))
                                    {
                                        <span class="badge text-bg-danger">
                                            Entered In Error
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge text-bg-secondary">
                                            @allergy.Status
                                        </span>
                                    }
                                    @if (!string.Equals(allergy.Status, "Active", StringComparison.OrdinalIgnoreCase)
                                        && allergy.UpdatedAt.HasValue)
                                    {
                                        <div class="small text-muted mt-1">
                                            Resolved @allergy.UpdatedAt.Value.ToLocalTime().ToString("MMM d, yyyy")
                                        </div>
                                    }
                                </td>

                                <td class="text-end">
                                    @if (string.Equals(allergy.Status, "Active", StringComparison.OrdinalIgnoreCase))
                                    {
                                        <button type="button" class="btn btn-sm btn-outline-danger resolve-allergy-button"
                                                data-patient-uid="@allergy.PatientUid" data-allergy-uid="@allergy.AllergyUid">
                                            Resolve Allergy
                                        </button>
                                        <a asp-controller="PatientAllergies"
                                           asp-action="Edit"
                                           asp-route-allergyUid="@allergy.AllergyUid"
                                           class="btn btn-sm btn-outline-secondary">
                                            Edit
                                        </a>
                                    }
                                    <a asp-controller="PatientAllergies"
                                       asp-action="Details"
                                       asp-route-allergyUid="@allergy.AllergyUid"
                                       class="btn btn-sm btn-outline-primary">
                                        Open
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

    <div class="tab-pane fade @(medicationsActive ? "show active" : null)"
         id="medications"
         role="tabpanel">

        <div class="d-flex justify-content-between align-items-center gap-3 mb-3">
            <h5 class="mb-0">Patient Medications</h5>
            <div class="d-flex align-items-center gap-2">
                <label for="medicationStatusFilter" class="form-label mb-0">Show</label>
                <select id="medicationStatusFilter" class="form-select form-select-sm" aria-label="Filter medications by status">
                    <option value="Active" selected>Active</option>
                    <option value="Discontinued">Discontinued</option>
                    <option value="All">All</option>
                </select>
                <a asp-controller="PatientMedications"
                   asp-action="Create"
                   asp-route-patientUid="@patient.PatientUid"
                   class="btn btn-primary text-nowrap">
                    <i class="bi bi-plus-circle me-1"></i>
                    Add Medication
                </a>
            </div>
        </div>

        <div id="medicationEmptyState" class="alert alert-light border d-none">
            <i class="bi bi-capsule me-2"></i>
            <span>No active medications recorded.</span>
        </div>

        @if (Model.Medications.Count > 0)
        {
            <div id="medicationTableContainer" class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Medication</th>
                            <th>Strength</th>
                            <th>Directions</th>
                            <th>Frequency</th>
                            <th>Start</th>
                            <th>Status</th>
                            <th class="text-end">Action</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var medication in Model.Medications)
                        {
                            <tr data-medication-status="@medication.Status">
                                <td>
                                    <strong>@medication.MedicationName</strong>
                                </td>

                                <td>
                                    @(medication.Strength ?? "—")
                                </td>

                                <td>
                                    @(medication.Directions ?? "—")
                                </td>

                                <td>
                                    @(medication.Frequency ?? "—")
                                </td>

                                <td>
                                    @(medication.StartDate.HasValue
                                        ? medication.StartDate.Value.ToString("MMM d, yyyy")
                                        : "—")
                                </td>

                                <td>
                                    @if (string.Equals(
                                        medication.Status,
                                        "Active",
                                        StringComparison.OrdinalIgnoreCase))
                                    {
                                        <span class="badge text-bg-success">
                                            Active
                                        </span>
                                    }
                                    else if (string.Equals(
                                        medication.Status,
                                        "Inactive",
                                        StringComparison.OrdinalIgnoreCase))
                                    {
                                        <span class="badge text-bg-secondary">
                                            Inactive
                                        </span>
                                    }
                                    else if (string.Equals(
                                        medication.Status,
                                        "Discontinued",
                                        StringComparison.OrdinalIgnoreCase))
                                    {
                                        <span class="badge text-bg-warning">
                                            Discontinued
                                        </span>
                                    }
                                    else if (string.Equals(
                                        medication.Status,
                                        "EnteredInError",
                                        StringComparison.OrdinalIgnoreCase))
                                    {
                                        <span class="badge text-bg-danger">
                                            Entered In Error
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge text-bg-secondary">
                                            @medication.Status
                                        </span>
                                    }
                                    @if (!string.Equals(medication.Status, "Active", StringComparison.OrdinalIgnoreCase))
                                    {
                                        if (medication.EndDate.HasValue)
                                        {
                                            <div class="small text-muted mt-1">
                                                Discontinued @medication.EndDate.Value.ToString("MMM d, yyyy")
                                            </div>
                                        }
                                        else if (medication.UpdatedAt.HasValue)
                                        {
                                            <div class="small text-muted mt-1">
                                                Discontinued @medication.UpdatedAt.Value.ToLocalTime().ToString("MMM d, yyyy")
                                            </div>
                                        }
                                    }
                                </td>

                                <td class="text-end">
                                    @if (string.Equals(medication.Status, "Active", StringComparison.OrdinalIgnoreCase))
                                    {
                                        <button type="button" class="btn btn-sm btn-outline-danger discontinue-medication-button"
                                                data-patient-uid="@medication.PatientUid"
                                                data-medication-uid="@medication.MedicationUid">
                                            Discontinue
                                        </button>
                                        <a asp-controller="PatientMedications"
                                           asp-action="Edit"
                                           asp-route-medicationUid="@medication.MedicationUid"
                                           class="btn btn-sm btn-outline-secondary">Edit</a>
                                    }
                                    <a asp-controller="PatientMedications"
                                       asp-action="Details"
                                       asp-route-medicationUid="@medication.MedicationUid"
                                       class="btn btn-sm btn-outline-primary">
                                        Open
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<div class="modal fade" id="encounterDetailsModal" tabindex="-1" aria-labelledby="encounterDetailsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title fs-5" id="encounterDetailsModalLabel">Encounter Details</h2>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div id="encounterDetailsMessage" class="alert alert-danger d-none" role="alert"></div>
                <div id="encounterDetailsLoading" class="text-center py-4">
                    <div class="spinner-border text-primary" role="status"><span class="visually-hidden">Loading encounter details...</span></div>
                    <p class="text-muted mt-2 mb-0">Loading encounter details...</p>
                </div>
                <div id="encounterDetailsContent" class="d-none">
                    <div class="row g-4">
                        <div class="col-12 col-md-6">
                            <dl class="row mb-0">
                                <dt class="col-sm-5">Date/time</dt><dd class="col-sm-7" id="encounterDetailsDate"></dd>
                                <dt class="col-sm-5">Type</dt><dd class="col-sm-7" id="encounterDetailsType"></dd>
                                <dt class="col-sm-5">Status</dt><dd class="col-sm-7" id="encounterDetailsStatus"></dd>
                                <dt class="col-sm-5">Provider</dt><dd class="col-sm-7" id="encounterDetailsProvider"></dd>
                                <dt class="col-sm-5">Location</dt><dd class="col-sm-7" id="encounterDetailsLocation"></dd>
                            </dl>
                        </div>
                        <div class="col-12 col-md-6">
                            <dl class="row mb-0">
                                <dt class="col-sm-5">Created by</dt><dd class="col-sm-7" id="encounterDetailsCreatedBy"></dd>
                                <dt class="col-sm-5">Created</dt><dd class="col-sm-7" id="encounterDetailsCreatedAt"></dd>
                                <dt class="col-sm-5">Updated</dt><dd class="col-sm-7" id="encounterDetailsUpdatedAt"></dd>
                                <dt class="col-sm-5 d-none" id="encounterDetailsSignedAtLabel">Signed</dt>
                                <dd class="col-sm-7 d-none" id="encounterDetailsSignedAt"></dd>
                                <dt class="col-sm-5 d-none" id="encounterDetailsSignedByLabel">Signed by</dt>
                                <dd class="col-sm-7 d-none" id="encounterDetailsSignedBy"></dd>
                            </dl>
                        </div>
                        <div class="col-12">
                            <h3 class="fs-6">Reason for Visit</h3>
                            <p class="mb-0 text-break" id="encounterDetailsReason"></p>
                        </div>
                        <div class="col-12">
                            <label for="encounterNoteText" class="form-label fw-semibold">Encounter Note</label>
                            <textarea id="encounterNoteText"
                                      name="Notes"
                                      class="form-control"
                                      rows="8"></textarea>
                            <div id="encounterNoteMessage"
                                 class="alert d-none mt-3 mb-0"
                                 role="status"></div>
                            <div class="d-flex justify-content-end gap-2 mt-3">
                                <button type="button"
                                        class="btn btn-outline-danger"
                                        id="signEncounterButton">
                                    Sign Encounter
                                </button>
                                <button type="button"
                                        class="btn btn-primary"
                                        id="saveEncounterNoteButton">
                                    Save Note
                                </button>
                            </div>
                        </div>
                        <div class="col-12">
                            <h3 class="fs-6">Addendums</h3>
                            <p id="encounterAddendumHelper" class="small text-muted mb-3">
                                Addendums are available after the encounter is signed.
                            </p>
                            <div id="encounterAddendumForm" class="d-none border rounded p-3 mb-3">
                                <label for="encounterAddendumText" class="form-label">Add Addendum</label>
                                <textarea id="encounterAddendumText" class="form-control" rows="4"></textarea>
                                <div id="encounterAddendumMessage" class="alert d-none mt-3 mb-0" role="status"></div>
                                <div class="d-flex justify-content-end gap-2 mt-3">
                                    <button type="button" class="btn btn-outline-secondary" id="cancelEncounterAddendumButton">
                                        Cancel
                                    </button>
                                    <button type="button" class="btn btn-primary" id="saveEncounterAddendumButton">
                                        Save Addendum
                                    </button>
                                </div>
                            </div>
                            <div id="encounterAddendumsContent" aria-live="polite"></div>
                        </div>
                        <div class="col-12">
                            <div class="d-flex align-items-center justify-content-between">
                                <h3 class="fs-6 mb-0">Encounter History</h3>
                                <button type="button"
                                        class="btn btn-sm btn-outline-secondary"
                                        id="viewEncounterHistoryButton">
                                    View History
                                </button>
                            </div>
                            <div id="encounterHistoryContent"
                                 class="mt-3 d-none"
                                 aria-live="polite"></div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button></div>
        </div>
    </div>
</div>

<div class="modal fade" id="signEncounterModal" tabindex="-1" aria-labelledby="signEncounterModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title fs-5" id="signEncounterModalLabel">Sign Encounter</h2>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div id="signEncounterMessage" class="alert alert-danger d-none" role="alert"></div>
                <p class="mb-0">Signing this encounter will lock the note from further editing.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" id="keepEditingEncounterButton">Keep Editing</button>
                <button type="button" class="btn btn-danger" id="confirmSignEncounterButton">Sign Encounter</button>
            </div>
        </div>
    </div>
</div>
<form id="encounterNoteAntiforgeryForm" class="d-none">@Html.AntiForgeryToken()</form>

<div class="modal fade" id="resolveAllergyModal" tabindex="-1" aria-labelledby="resolveAllergyModalLabel" aria-hidden="true">
 <div class="modal-dialog"><div class="modal-content">
  <div class="modal-header"><h2 class="modal-title fs-5" id="resolveAllergyModalLabel">Resolve Allergy</h2><button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button></div>
  <div class="modal-body"><div id="resolveAllergyMessage" class="alert alert-danger d-none"></div><p>Are you sure you want to resolve this allergy?</p><label for="resolveAllergyReason" class="form-label">Reason (optional)</label><textarea id="resolveAllergyReason" class="form-control" maxlength="500" rows="3"></textarea></div>
  <div class="modal-footer"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button><button type="button" class="btn btn-danger" id="confirmResolveAllergyButton">Confirm Resolve</button></div>
 </div></div>
</div>
<form id="allergyAntiforgeryForm" class="d-none">@Html.AntiForgeryToken()</form>

<div class="modal fade" id="discontinueMedicationModal" tabindex="-1" aria-labelledby="discontinueMedicationModalLabel" aria-hidden="true">
    <div class="modal-dialog"><div class="modal-content">
        <div class="modal-header"><h2 class="modal-title fs-5" id="discontinueMedicationModalLabel">Discontinue Medication</h2><button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button></div>
        <div class="modal-body">
            <div id="discontinueMedicationMessage" class="alert alert-danger d-none"></div>
            <p>Are you sure you want to discontinue this medication?</p>
            <label for="discontinueMedicationReason" class="form-label">Reason (optional)</label>
            <textarea id="discontinueMedicationReason" class="form-control" maxlength="500" rows="3"></textarea>
        </div>
        <div class="modal-footer"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button><button type="button" class="btn btn-danger" id="confirmDiscontinueMedicationButton">Confirm Discontinue</button></div>
    </div></div>
</div>
<form id="medicationAntiforgeryForm" class="d-none">@Html.AntiForgeryToken()</form>

@section Scripts {
<script>
document.addEventListener("DOMContentLoaded", () => {
    const modalElement = document.getElementById("encounterDetailsModal");
    const modal = new bootstrap.Modal(modalElement);
    const loading = document.getElementById("encounterDetailsLoading");
    const content = document.getElementById("encounterDetailsContent");
    const message = document.getElementById("encounterDetailsMessage");
    const noteText = document.getElementById("encounterNoteText");
    const noteMessage = document.getElementById("encounterNoteMessage");
    const saveNoteButton = document.getElementById("saveEncounterNoteButton");
    const signEncounterButton = document.getElementById("signEncounterButton");
    const signModalElement = document.getElementById("signEncounterModal");
    const signModal = new bootstrap.Modal(signModalElement);
    const signMessage = document.getElementById("signEncounterMessage");
    const confirmSignButton = document.getElementById("confirmSignEncounterButton");
    const viewHistoryButton = document.getElementById("viewEncounterHistoryButton");
    const historyContent = document.getElementById("encounterHistoryContent");
    const addendumHelper = document.getElementById("encounterAddendumHelper");
    const addendumForm = document.getElementById("encounterAddendumForm");
    const addendumText = document.getElementById("encounterAddendumText");
    const addendumMessage = document.getElementById("encounterAddendumMessage");
    const saveAddendumButton = document.getElementById("saveEncounterAddendumButton");
    const cancelAddendumButton = document.getElementById("cancelEncounterAddendumButton");
    const addendumsContent = document.getElementById("encounterAddendumsContent");
    const detailsUrl = '@Url.Action("EncounterDetails", "PatientEncounters")';
    const encounterHistoryUrl = '@Url.Action("EncounterHistory", "PatientEncounters")';
    const updateNoteUrl = '@Url.Action("UpdateEncounterNote", "PatientEncounters")';
    const signEncounterUrl = '@Url.Action("SignEncounter", "PatientEncounters")';
    const encounterAddendumsUrl = '@Url.Action("EncounterAddendums", "PatientEncounters")';
    const createEncounterAddendumUrl = '@Url.Action("CreateEncounterAddendum", "PatientEncounters")';
    const emptyValue = "—";
    let currentPatientUid = null;
    let currentEncounterUid = null;
    let currentEncounterIsEditable = false;
    let historyLoaded = false;

    const formatDate = value => value
        ? new Intl.DateTimeFormat(undefined, { dateStyle: "medium", timeStyle: "short" }).format(new Date(value))
        : emptyValue;

    const setText = (id, value) => {
        document.getElementById(id).textContent = value || emptyValue;
    };

    const setOptionalDetail = (labelId, valueId, value) => {
        document.getElementById(labelId).classList.toggle("d-none", !value);
        document.getElementById(valueId).classList.toggle("d-none", !value);
        document.getElementById(valueId).textContent = value || "";
    };

    const applyEncounterDetails = encounter => {
        setText("encounterDetailsDate", formatDate(encounter.encounterDateUtc));
        setText("encounterDetailsType", encounter.encounterType);
        setText("encounterDetailsStatus", encounter.status);
        setText("encounterDetailsProvider", encounter.providerName);
        setText("encounterDetailsLocation", encounter.locationName);
        setText("encounterDetailsCreatedBy", encounter.createdByDisplayName || "Unknown");
        setText("encounterDetailsCreatedAt", formatDate(encounter.createdAt));
        setText("encounterDetailsUpdatedAt", formatDate(encounter.updatedAt));
        setText("encounterDetailsReason", encounter.reasonForVisit);
        setOptionalDetail(
            "encounterDetailsSignedAtLabel",
            "encounterDetailsSignedAt",
            encounter.signedAt ? formatDate(encounter.signedAt) : null);
        setOptionalDetail(
            "encounterDetailsSignedByLabel",
            "encounterDetailsSignedBy",
            encounter.signedByDisplayName);
        noteText.value = encounter.notes || "";
        currentPatientUid = encounter.patientUid;
        currentEncounterUid = encounter.encounterUid;
        currentEncounterIsEditable =
            String(encounter.status).toLowerCase() === "open";
        noteText.readOnly = !currentEncounterIsEditable;
        saveNoteButton.classList.toggle("d-none", !currentEncounterIsEditable);
        saveNoteButton.disabled = !currentEncounterIsEditable;
        signEncounterButton.classList.toggle("d-none", !currentEncounterIsEditable);
        signEncounterButton.disabled = !currentEncounterIsEditable;
        const isSigned = String(encounter.status).toLowerCase() === "signed";
        addendumHelper.classList.toggle("d-none", isSigned);
        addendumForm.classList.toggle("d-none", !isSigned);
        addendumText.disabled = !isSigned;
        saveAddendumButton.disabled = !isSigned;
    };

    const renderAddendums = addendums => {
        addendumsContent.className = "";
        addendumsContent.replaceChildren();
        if (!addendums.length) {
            const empty = document.createElement("p");
            empty.className = "text-muted mb-0";
            empty.textContent = "No addendums have been added.";
            addendumsContent.appendChild(empty);
            return;
        }

        addendums.forEach(addendum => {
            const card = document.createElement("div");
            card.className = "card mb-2";
            const body = document.createElement("div");
            body.className = "card-body";
            const metadata = document.createElement("div");
            metadata.className = "small text-muted mb-2";
            metadata.textContent = `${formatDate(addendum.createdAt)} · ${addendum.createdByDisplayName || "Unknown"}`;
            const text = document.createElement("p");
            text.className = "mb-0 text-break";
            text.style.whiteSpace = "pre-wrap";
            text.textContent = addendum.addendumText || "";
            body.append(metadata, text);
            card.appendChild(body);
            addendumsContent.appendChild(card);
        });
    };

    const loadAddendums = async () => {
        if (!currentPatientUid || !currentEncounterUid) return;
        addendumsContent.className = "";
        addendumsContent.innerHTML =
            '<div class="text-muted"><span class="spinner-border spinner-border-sm me-2" aria-hidden="true"></span>Loading addendums...</div>';
        try {
            const query = new URLSearchParams({
                patientUid: currentPatientUid,
                encounterUid: currentEncounterUid
            });
            const response = await fetch(`${encounterAddendumsUrl}?${query}`, {
                headers: { "Accept": "application/json" }
            });
            const result = await response.json().catch(() => ({}));
            if (!response.ok || !result.success)
                throw new Error(result.message || "Encounter addendums could not be loaded.");
            renderAddendums(result.addendums || []);
        } catch (error) {
            addendumsContent.className = "alert alert-danger mb-0";
            addendumsContent.textContent = error instanceof Error
                ? error.message
                : "Encounter addendums could not be loaded.";
        }
    };

    const historyActionLabel = actionType => String(actionType || "")
        .replace(/([a-z])([A-Z])/g, "$1 $2")
        .replace(/^./, value => value.toUpperCase());

    const renderEncounterHistory = history => {
        historyContent.replaceChildren();
        if (!history.length) {
            const empty = document.createElement("p");
            empty.className = "text-muted mb-0";
            empty.textContent = "No encounter history is available.";
            historyContent.appendChild(empty);
            return;
        }

        const list = document.createElement("div");
        list.className = "list-group list-group-flush border rounded";
        history.forEach(item => {
            const row = document.createElement("div");
            row.className = "list-group-item";
            const title = document.createElement("div");
            title.className = "fw-semibold";
            title.textContent = historyActionLabel(item.actionType);
            const status = document.createElement("div");
            status.className = "small";
            status.textContent = item.oldStatus && item.newStatus
                ? `${item.oldStatus} \u2192 ${item.newStatus}`
                : (item.actionDescription || "");
            const description = document.createElement("div");
            description.className = "small text-muted";
            description.textContent =
                item.oldStatus && item.newStatus && item.actionDescription
                    ? item.actionDescription
                    : "";
            const date = document.createElement("div");
            date.className = "small text-muted mt-1";
            date.textContent = formatDate(item.createdAt);
            row.append(title, status);
            if (description.textContent) row.appendChild(description);
            row.appendChild(date);
            list.appendChild(row);
        });
        historyContent.appendChild(list);
    };

    const resetEncounterHistory = () => {
        historyLoaded = false;
        historyContent.replaceChildren();
        historyContent.className = "mt-3 d-none";
        viewHistoryButton.textContent = "View History";
        viewHistoryButton.disabled = false;
    };

    const openEncounter = async (patientUid, encounterUid) => {
        loading.classList.remove("d-none");
        content.classList.add("d-none");
        message.classList.add("d-none");
        message.textContent = "";
        noteMessage.className = "alert d-none mt-3 mb-0";
        noteMessage.textContent = "";
        noteText.value = "";
        saveNoteButton.disabled = true;
        signEncounterButton.disabled = true;
        currentPatientUid = null;
        currentEncounterUid = null;
        currentEncounterIsEditable = false;
        addendumText.value = "";
        addendumMessage.className = "alert d-none mt-3 mb-0";
        addendumMessage.textContent = "";
        addendumsContent.replaceChildren();
        resetEncounterHistory();
        modal.show();

        try {
            const query = new URLSearchParams({ patientUid, encounterUid });
            const response = await fetch(`${detailsUrl}?${query}`, { headers: { "Accept": "application/json" } });
            const result = await response.json().catch(() => ({}));

            if (!response.ok || !result.success || !result.encounter) {
                throw new Error(result.message || "Encounter details could not be loaded.");
            }

            const encounter = result.encounter;
            applyEncounterDetails(encounter);
            await loadAddendums();
            content.classList.remove("d-none");
        } catch (error) {
            message.textContent = error instanceof Error
                ? error.message
                : "Encounter details could not be loaded.";
            message.classList.remove("d-none");
        } finally {
            loading.classList.add("d-none");
        }
    };

    viewHistoryButton.addEventListener("click", async () => {
        if (!currentPatientUid || !currentEncounterUid) return;
        if (historyLoaded) {
            historyContent.classList.toggle("d-none");
            viewHistoryButton.textContent = historyContent.classList.contains("d-none")
                ? "View History"
                : "Hide History";
            return;
        }

        viewHistoryButton.disabled = true;
        historyContent.className = "mt-3";
        historyContent.innerHTML =
            '<div class="text-muted"><span class="spinner-border spinner-border-sm me-2" aria-hidden="true"></span>Loading encounter history...</div>';
        try {
            const query = new URLSearchParams({
                patientUid: currentPatientUid,
                encounterUid: currentEncounterUid
            });
            const response = await fetch(`${encounterHistoryUrl}?${query}`, {
                headers: { "Accept": "application/json" }
            });
            const result = await response.json().catch(() => ({}));
            if (!response.ok || !result.success) {
                throw new Error(result.message || "Encounter history could not be loaded.");
            }
            renderEncounterHistory(result.history || []);
            historyLoaded = true;
            viewHistoryButton.textContent = "Hide History";
        } catch (error) {
            historyContent.textContent = error instanceof Error
                ? error.message
                : "Encounter history could not be loaded.";
            historyContent.className = "alert alert-danger mt-3";
        } finally {
            viewHistoryButton.disabled = false;
        }
    });

    saveNoteButton.addEventListener("click", async () => {
        if (!currentPatientUid || !currentEncounterUid || !currentEncounterIsEditable) {
            return;
        }

        saveNoteButton.disabled = true;
        noteMessage.className = "alert d-none mt-3 mb-0";
        noteMessage.textContent = "";

        try {
            const formData = new FormData();
            formData.append("PatientUid", currentPatientUid);
            formData.append("EncounterUid", currentEncounterUid);
            formData.append("Notes", noteText.value);

            const token = document.querySelector(
                '#encounterNoteAntiforgeryForm input[name="__RequestVerificationToken"]').value;
            const response = await fetch(updateNoteUrl, {
                method: "POST",
                headers: {
                    "Accept": "application/json",
                    "RequestVerificationToken": token
                },
                body: formData
            });
            const result = await response.json().catch(() => ({}));

            if (!response.ok || !result.success) {
                throw new Error(result.message || "Encounter note could not be saved.");
            }

            noteText.value = result.notes || "";
            setText("encounterDetailsUpdatedAt", formatDate(result.updatedAt));
            resetEncounterHistory();
            noteMessage.className = "alert alert-success mt-3 mb-0";
            noteMessage.textContent = result.message || "Encounter note saved.";
        } catch (error) {
            noteMessage.className = "alert alert-danger mt-3 mb-0";
            noteMessage.textContent = error instanceof Error
                ? error.message
                : "Encounter note could not be saved.";
        } finally {
            saveNoteButton.disabled = !currentEncounterIsEditable;
        }
    });

    cancelAddendumButton.addEventListener("click", () => {
        addendumText.value = "";
        addendumMessage.className = "alert d-none mt-3 mb-0";
        addendumMessage.textContent = "";
    });

    saveAddendumButton.addEventListener("click", async () => {
        if (!currentPatientUid || !currentEncounterUid || !addendumText.value.trim()) {
            addendumMessage.className = "alert alert-danger mt-3 mb-0";
            addendumMessage.textContent = "Addendum text is required.";
            return;
        }

        saveAddendumButton.disabled = true;
        addendumMessage.className = "alert d-none mt-3 mb-0";
        try {
            const formData = new FormData();
            formData.append("PatientUid", currentPatientUid);
            formData.append("EncounterUid", currentEncounterUid);
            formData.append("AddendumText", addendumText.value);
            const token = document.querySelector(
                '#encounterNoteAntiforgeryForm input[name="__RequestVerificationToken"]').value;
            const response = await fetch(createEncounterAddendumUrl, {
                method: "POST",
                headers: { "Accept": "application/json", "RequestVerificationToken": token },
                body: formData
            });
            const result = await response.json().catch(() => ({}));
            if (!response.ok || !result.success)
                throw new Error(result.message || "Addendum could not be saved.");

            addendumText.value = "";
            await loadAddendums();
            resetEncounterHistory();
            addendumMessage.className = "alert alert-success mt-3 mb-0";
            addendumMessage.textContent = result.message || "Addendum saved.";
        } catch (error) {
            addendumMessage.className = "alert alert-danger mt-3 mb-0";
            addendumMessage.textContent = error instanceof Error
                ? error.message
                : "Addendum could not be saved.";
        } finally {
            saveAddendumButton.disabled = false;
        }
    });

    signEncounterButton.addEventListener("click", () => {
        if (!currentPatientUid || !currentEncounterUid || !currentEncounterIsEditable) {
            return;
        }

        signMessage.classList.add("d-none");
        signMessage.textContent = "";
        modalElement.addEventListener(
            "hidden.bs.modal",
            () => signModal.show(),
            { once: true });
        modal.hide();
    });

    document.getElementById("keepEditingEncounterButton").addEventListener("click", () => {
        signModalElement.addEventListener(
            "hidden.bs.modal",
            () => modal.show(),
            { once: true });
        signModal.hide();
    });

    confirmSignButton.addEventListener("click", async () => {
        if (!currentPatientUid || !currentEncounterUid) {
            return;
        }

        confirmSignButton.disabled = true;
        signMessage.classList.add("d-none");
        signMessage.textContent = "";

        try {
            const formData = new FormData();
            formData.append("patientUid", currentPatientUid);
            formData.append("encounterUid", currentEncounterUid);
            const token = document.querySelector(
                '#encounterNoteAntiforgeryForm input[name="__RequestVerificationToken"]').value;
            const response = await fetch(signEncounterUrl, {
                method: "POST",
                headers: {
                    "Accept": "application/json",
                    "RequestVerificationToken": token
                },
                body: formData
            });
            const result = await response.json().catch(() => ({}));

            if (!response.ok || !result.success || !result.encounter) {
                throw new Error(result.message || "Encounter could not be signed.");
            }

            applyEncounterDetails(result.encounter);
            await loadAddendums();
            resetEncounterHistory();
            signModalElement.addEventListener("hidden.bs.modal", () => {
                noteMessage.className = "alert alert-success mt-3 mb-0";
                noteMessage.textContent = result.message || "Encounter signed.";
                modal.show();
            }, { once: true });
            signModal.hide();
        } catch (error) {
            signMessage.textContent = error instanceof Error
                ? error.message
                : "Encounter could not be signed.";
            signMessage.classList.remove("d-none");
        } finally {
            confirmSignButton.disabled = false;
        }
    });

    document.querySelectorAll(".open-encounter-button").forEach(button => {
        button.addEventListener("click", () => openEncounter(
            button.dataset.patientUid,
            button.dataset.encounterUid));
    });
});

document.addEventListener("DOMContentLoaded", () => {
    const configureStatusFilter = ({ selectId, rowSelector, tableId, emptyId, inactiveValue, emptyMessages }) => {
        const select = document.getElementById(selectId);
        const rows = Array.from(document.querySelectorAll(rowSelector));
        const table = document.getElementById(tableId);
        const empty = document.getElementById(emptyId);
        if (!select || !empty) return;

        const applyFilter = () => {
            const filter = select.value;
            let visibleCount = 0;
            rows.forEach(row => {
                const status = String(row.dataset.allergyStatus || row.dataset.medicationStatus || "");
                const isVisible = filter === "All"
                    || (filter === "Active" && status.toLowerCase() === "active")
                    || (filter === inactiveValue &&
                        (status.toLowerCase() === inactiveValue.toLowerCase()
                            || status.toLowerCase() === "inactive"));
                row.classList.toggle("d-none", !isVisible);
                if (isVisible) visibleCount++;
            });

            table?.classList.toggle("d-none", visibleCount === 0);
            empty.classList.toggle("d-none", visibleCount !== 0);
            const text = empty.querySelector("span");
            if (text) text.textContent = emptyMessages[filter];
        };

        select.addEventListener("change", applyFilter);
        applyFilter();
    };

    configureStatusFilter({
        selectId: "allergyStatusFilter",
        rowSelector: "tr[data-allergy-status]",
        tableId: "allergyTableContainer",
        emptyId: "allergyEmptyState",
        inactiveValue: "Resolved",
        emptyMessages: {
            Active: "No active allergies recorded.",
            Resolved: "No resolved allergies recorded.",
            All: "No allergies recorded."
        }
    });

    configureStatusFilter({
        selectId: "medicationStatusFilter",
        rowSelector: "tr[data-medication-status]",
        tableId: "medicationTableContainer",
        emptyId: "medicationEmptyState",
        inactiveValue: "Discontinued",
        emptyMessages: {
            Active: "No active medications recorded.",
            Discontinued: "No discontinued medications recorded.",
            All: "No medications recorded."
        }
    });

    const modal = new bootstrap.Modal(document.getElementById("resolveAllergyModal"));
    const reason = document.getElementById("resolveAllergyReason");
    const message = document.getElementById("resolveAllergyMessage");
    const confirmButton = document.getElementById("confirmResolveAllergyButton");
    let patientUid = null, allergyUid = null;
    document.querySelectorAll(".resolve-allergy-button").forEach(button => button.addEventListener("click", () => {
        patientUid = button.dataset.patientUid; allergyUid = button.dataset.allergyUid;
        reason.value = ""; message.classList.add("d-none"); modal.show();
    }));
    confirmButton.addEventListener("click", async () => {
        if (!patientUid || !allergyUid) return;
        confirmButton.disabled = true; message.classList.add("d-none");
        try {
            const data = new FormData(); data.append("PatientUid", patientUid); data.append("AllergyUid", allergyUid); data.append("ResolveReason", reason.value);
            const token = document.querySelector('#allergyAntiforgeryForm input[name="__RequestVerificationToken"]').value;
            const response = await fetch('@Url.Action("ResolveAllergy", "PatientAllergies")', { method: "POST", headers: { "RequestVerificationToken": token }, body: data });
            const result = await response.json().catch(() => ({}));
            if (!response.ok || !result.success) { message.textContent = result.message || "Allergy could not be resolved."; message.classList.remove("d-none"); return; }
            window.location.href = '@Url.Action("Details", "Patients", new { patientUid = patient.PatientUid, tab = "allergies" })';
        } catch { message.textContent = "Allergy could not be resolved."; message.classList.remove("d-none"); }
        finally { confirmButton.disabled = false; }
    });
});

