@model MicroEMR.Web.Models.Patients.PatientSearchResponse

@{
    ViewData["Title"] = "Patients";
    ViewData["Subtitle"] = "Search and manage patient records";
    Layout = "_AppLayout";

    var searchText = ViewBag.SearchText as string;
    DateOnly? dateOfBirth = ViewBag.DateOfBirth;
}

<div class="content-panel">

    <div class="content-panel-header">
        <div>
            <h3>Patient Directory</h3>
            <p>Search by name, chart number, health card or phone</p>
        </div>

        <a asp-action="Create"
           class="btn btn-primary">
            <i class="bi bi-person-plus me-1"></i>
            Register patient
        </a>
    </div>

    <div asp-validation-summary="ModelOnly"
         class="alert alert-danger mt-3">
    </div>

    <form method="get"
          asp-action="Search"
          class="row g-3 mt-1">

        <div class="col-12 col-lg-6">
            <label class="form-label">
                Search
            </label>

            <input type="text"
                   name="searchText"
                   value="@searchText"
                   class="form-control"
                   placeholder="Name, chart number, health card or phone" />
        </div>

        <div class="col-12 col-sm-6 col-lg-3">
            <label class="form-label">
                Date of birth
            </label>

            <input type="date"
                   name="dateOfBirth"
                   value="@dateOfBirth?.ToString("yyyy-MM-dd")"
                   class="form-control" />
        </div>

        <div class="col-12 col-sm-6 col-lg-3 d-flex align-items-end gap-2">
            <button type="submit"
                    class="btn btn-primary flex-grow-1">
                <i class="bi bi-search me-1"></i>
                Search
            </button>

            <a asp-action="Search"
               class="btn btn-outline-secondary">
                Clear
            </a>
        </div>
    </form>

    <div class="table-responsive mt-4">
        <table class="table table-hover align-middle">

            <thead>
                <tr>
                    <th>Chart</th>
                    <th>Patient</th>
                    <th>Date of birth</th>
                    <th>Health card</th>
                    <th>Phone</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>

            <tbody>
                @if (Model.Items.Count == 0)
                {
                    <tr>
                        <td colspan="6"
                            class="text-center text-muted py-5">
                            No patients found.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var patient in Model.Items)
                    {
                        <tr>
                            <td class="fw-semibold">
                                @patient.ChartNumber
                            </td>

                            <td>
                                <div class="fw-semibold">
                                    @patient.FullName
                                </div>

                                @if (!string.IsNullOrWhiteSpace(
                                        patient.LastName))
                                {
                                    <small class="text-muted">
                                        Preferred:
                                        @patient.LastName, @patient.FirstName
                                    </small>
                                }
                            </td>

                            <td>
                                @patient.DateOfBirth.ToString("yyyy-MM-dd")
                            </td>

                            <td>
                                @patient.HealthCardNumber

                                @if (!string.IsNullOrWhiteSpace(
                                        patient.HealthCardVersion))
                                {
                                    <span>
                                        - @patient.HealthCardVersion
                                    </span>
                                }
                            </td>

                            <td>
                                @patient.PhoneNumber
                            </td>

                            <td class="text-end">
                                <a asp-action="Details"
                                   asp-route-patientUid="@patient.PatientUid"
                                   class="btn btn-sm btn-outline-primary">
                                    Open chart
                                </a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>